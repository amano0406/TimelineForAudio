# Optional local data roots for direct host CLI use.
# If omitted, the CLI uses %LOCALAPPDATA%\TimelineForAudio on Windows
# or ~/.timeline-for-audio on Unix-like environments.
# TIMELINE_FOR_AUDIO_APPDATA_ROOT=C:\TimelineForAudio\app-data
# TIMELINE_FOR_AUDIO_OUTPUTS_ROOT=C:\TimelineForAudio\outputs
