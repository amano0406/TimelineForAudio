@page "/jobs"
@model TimelineForAudio.Web.Pages.Jobs.IndexModel
@using TimelineForAudio.Web.Infrastructure
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string StateLabel(string? value)
    {
        var key = $"state.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string StageLabel(string? value)
    {
        if (string.Equals(value, "skipped_duplicate", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.reused");
        }
        if (string.Equals(value, "skipped_invalid", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.skipped_invalid");
        }
        if (string.Equals(value, "skipped_too_short", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.skipped_too_short");
        }

        var key = $"stage.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string? SecondaryStageLabel(string? state, string? stage)
    {
        if (string.IsNullOrWhiteSpace(stage) ||
            string.Equals(stage, state, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var label = StageLabel(stage);
        return label == "-" ? null : label;
    }

    string FormatSize(long valueBytes) => DisplayFormatters.FormatFileSize(valueBytes, L);
    string FormatDuration(double? valueSeconds) => DisplayFormatters.FormatDurationFriendly(valueSeconds, L);
    string FormatDurationOrDash(double? valueSeconds) => valueSeconds.HasValue ? FormatDuration(valueSeconds) : "-";
    string FormatCreatedAt(string? value) => DisplayFormatters.FormatCreatedAt(value);
    int CompletedCount(int done, int skipped, int failed) => done + skipped + failed;

    double Percent(double raw, int completed, int total)
    {
        if (raw > 0)
        {
            return Math.Clamp(raw, 0, 100);
        }

        return total <= 0 ? 0 : Math.Round(completed * 100.0 / total, 1);
    }

    string PercentLabel(double value) => $"{Math.Round(value, 1):0.0}%";
    string StateBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "running" => "status-badge status-badge-info",
        "pending" => "status-badge status-badge-warning",
        "completed" => "status-badge status-badge-success",
        "failed" => "status-badge status-badge-danger",
        "canceled" => "status-badge status-badge-neutral",
        _ => "status-badge status-badge-neutral",
    };
    string OutputLabel(TimelineForAudio.Web.Models.RunSummary run)
    {
        if (run.HasIpaArchive && run.HasReadableTextArchive)
        {
            return $"{L("artifact.ipa")} + {L("artifact.readable_text")}";
        }

        if (run.HasReadableTextArchive)
        {
            return L("artifact.readable_text");
        }

        if (run.HasIpaArchive)
        {
            return L("artifact.ipa");
        }

        return "-";
    }
    ViewData["Title"] = L("jobs.list.page_title");
}

<section class="app-page space-y-6" id="jobs-page" data-has-active="@(Model.ActiveRun is not null ? "true" : "false")">
    <header class="page-hero">
        <div>
            <p class="eyebrow">@L("jobs.list.eyebrow")</p>
            <h1 class="page-title">@L("jobs.list.page_title")</h1>
            <p class="page-description">@L("jobs.list.description")</p>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-3">
            <a class="btn-secondary" href="/jobs/new">@L("layout.new_job")</a>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <section class="surface-status-strip">
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("jobs.list.summary_total")</div>
            <div class="surface-status-value">@Model.TotalRuns</div>
        </div>
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("jobs.list.summary_active")</div>
            <div class="surface-status-value">@Model.ActiveRuns</div>
        </div>
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("jobs.list.summary_completed")</div>
            <div class="surface-status-value">@Model.CompletedRuns</div>
        </div>
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("jobs.list.summary_attention")</div>
            <div class="surface-status-value">@Model.AttentionRuns</div>
        </div>
    </section>

    @if (Model.ActiveRun is not null)
    {
        var activePercent = Percent(
            Model.ActiveRun.ProgressPercent,
            CompletedCount(Model.ActiveRun.VideosDone, Model.ActiveRun.VideosSkipped, Model.ActiveRun.VideosFailed),
            Model.ActiveRun.VideosTotal);
        var activeStageLabel = SecondaryStageLabel(Model.ActiveRun.State, Model.ActiveRun.CurrentStage);
        <section class="work-surface">
            <div class="job-highlight-header">
                <div>
                    <p class="eyebrow">@L("jobs.active.title")</p>
                    <h2 class="section-title">@L("jobs.active.heading")</h2>
                </div>
                <a class="btn-primary" href="@JobUrls.Details(Model.ActiveRun.JobId)">@L("jobs.active.open_details")</a>
            </div>

            <div class="data-list mt-5">
                <article class="data-row data-row-emphasis">
                    <div class="data-row-main">
                        <div class="data-row-title-line">
                            <a class="data-row-title" href="@JobUrls.Details(Model.ActiveRun.JobId)">@Model.ActiveRun.JobId</a>
                            <span class="@StateBadgeClass(Model.ActiveRun.State)">@StateLabel(Model.ActiveRun.State)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(activeStageLabel))
                        {
                            <div class="data-row-meta">
                                <span>@activeStageLabel</span>
                            </div>
                        }
                    </div>
                    <div class="data-row-side">
                        <div class="data-row-progress">
                            <div class="data-row-progress-header">
                                <span class="metric-label">@L("common.progress")</span>
                                <span class="job-card-progress-value">@PercentLabel(activePercent)</span>
                            </div>
                            <div class="progress-track mt-3">
                                <div class="progress-fill" style="width:@(activePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                        <dl class="data-row-facts">
                            <div class="data-row-fact">
                                <dt>@L("common.total_size")</dt>
                                <dd>@FormatSize(Model.ActiveRun.TotalSizeBytes)</dd>
                            </div>
                            <div class="data-row-fact">
                                <dt>@L("common.total_duration")</dt>
                                <dd>@FormatDuration(Model.ActiveRun.TotalDurationSec)</dd>
                            </div>
                            <div class="data-row-fact">
                                <dt>@L("common.elapsed")</dt>
                                <dd>@FormatDurationOrDash(Model.ActiveRun.ElapsedWallSec)</dd>
                            </div>
                        </dl>
                    </div>
                </article>
            </div>
        </section>
    }

    <section class="work-surface">
        <div class="job-list-header">
            <div>
                <p class="eyebrow">@L("jobs.list.history_eyebrow")</p>
                <h2 class="section-title">@L("jobs.list.history_title")</h2>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="text-sm text-slate-500">
                    @string.Format(System.Globalization.CultureInfo.CurrentCulture, L("jobs.list.pagination_summary"), Model.PageNumber, Model.TotalPages)
                </div>
            }
        </div>

        @if (Model.RecentRuns.Count == 0)
        {
            <div class="empty-state mt-5">
                <div>@L("jobs.list.empty")</div>
            </div>
        }
        else
        {
            <div class="data-list mt-5">
                @foreach (var run in Model.RecentRuns)
                {
                    var percent = Percent(
                        run.ProgressPercent,
                        CompletedCount(run.VideosDone, run.VideosSkipped, run.VideosFailed),
                        run.VideosTotal);
                    var stageLabel = SecondaryStageLabel(run.State, run.CurrentStage);
                    var showDownload = run.HasDownloadableArchive &&
                        !string.Equals(run.State, "pending", StringComparison.OrdinalIgnoreCase) &&
                        !string.Equals(run.State, "running", StringComparison.OrdinalIgnoreCase);
                    <article class="data-row">
                        <div class="data-row-main">
                            <div class="data-row-title-line">
                                <a class="data-row-title" href="@JobUrls.Details(run.JobId)">@run.JobId</a>
                                <span class="@StateBadgeClass(run.State)">@StateLabel(run.State)</span>
                                @if (!string.IsNullOrWhiteSpace(stageLabel))
                                {
                                    <span class="badge-chip">@stageLabel</span>
                                }
                            </div>
                            <div class="data-row-meta">
                                <span>@FormatCreatedAt(run.CreatedAt)</span>
                                <span aria-hidden="true">•</span>
                                <span>@OutputLabel(run)</span>
                            </div>
                        </div>
                        <div class="data-row-side">
                            <div class="data-row-progress">
                                <div class="data-row-progress-header">
                                    <span class="metric-label">@L("common.progress")</span>
                                    <span class="job-card-progress-value">@PercentLabel(percent)</span>
                                </div>
                                <div class="progress-track mt-3">
                                    <div class="progress-fill" style="width:@(percent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                            </div>
                            <dl class="data-row-facts">
                                <div class="data-row-fact">
                                    <dt>@L("common.total_size")</dt>
                                    <dd>@FormatSize(run.TotalSizeBytes)</dd>
                                </div>
                                <div class="data-row-fact">
                                    <dt>@L("common.total_duration")</dt>
                                    <dd>@FormatDuration(run.TotalDurationSec)</dd>
                                </div>
                                <div class="data-row-fact">
                                    <dt>@L("common.elapsed")</dt>
                                    <dd>@FormatDurationOrDash(run.ElapsedWallSec)</dd>
                                </div>
                            </dl>
                        </div>
                        <div class="data-row-actions">
                            <a class="btn-table" href="@JobUrls.Details(run.JobId)">@L("common.details")</a>
                            @if (showDownload)
                            {
                                <button type="button"
                                        class="btn-table-success"
                                        data-download-job-id="@run.JobId"
                                        data-download-readable="@(run.HasReadableTextArchive ? JobUrls.Download(run.JobId, "readable-text") : "")"
                                        data-download-ipa="@(run.HasIpaArchive ? JobUrls.Download(run.JobId, "ipa") : "")">
                                    @L("details.download_zip")
                                </button>
                            }
                            <form method="post" asp-page-handler="Delete" class="inline">
                                <input type="hidden" name="jobId" value="@run.JobId" />
                                <button class="btn-table-danger"
                                        type="submit"
                                        data-confirm-kind="delete-one"
                                        data-confirm-title="@L("common.delete")"
                                        data-confirm-message="@string.Format(System.Globalization.CultureInfo.CurrentCulture, L("jobs.list.delete_one_confirm"), run.JobId)"
                                        data-confirm-requires-text="false">
                                    @L("common.delete")
                                </button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <div class="mt-5 flex items-center justify-end gap-2">
                @if (Model.PageNumber > 1)
                {
                    <a class="btn-table" href="/jobs?pageNumber=@(Model.PageNumber - 1)">@L("common.previous")</a>
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a class="btn-table" href="/jobs?pageNumber=@(Model.PageNumber + 1)">@L("common.next")</a>
                }
            </div>
        }
    </section>
</section>

<div id="confirm-modal"
     class="modal-shell hidden"
     role="dialog"
     aria-modal="true"
     aria-labelledby="confirm-modal-title">
    <div class="modal-backdrop" data-modal-close="true"></div>
    <div class="modal-card">
        <div class="space-y-3">
            <h2 class="section-title" id="confirm-modal-title"></h2>
            <p class="page-description !mt-0" id="confirm-modal-message"></p>
            <div id="confirm-modal-input-wrap" class="hidden space-y-2">
                <label class="metric-label" for="confirm-modal-input">@L("common.confirm_text")</label>
                <input id="confirm-modal-input"
                       type="text"
                       class="form-input"
                       autocomplete="off"
                       spellcheck="false" />
                <p id="confirm-modal-error" class="text-sm text-rose-700 hidden"></p>
            </div>
        </div>
        <div class="mt-6 flex items-center justify-end gap-3">
            <button type="button" class="btn-secondary" id="confirm-modal-cancel">@L("common.cancel")</button>
            <button type="button" class="btn-table-danger" id="confirm-modal-submit">@L("common.delete")</button>
        </div>
    </div>
</div>

<div id="download-modal"
     class="modal-shell hidden"
     role="dialog"
     aria-modal="true"
     aria-labelledby="download-modal-title">
    <div class="modal-backdrop" data-download-close="true"></div>
    <div class="modal-card">
        <div class="space-y-3">
            <h2 class="section-title" id="download-modal-title">@L("jobs.list.download_title")</h2>
            <p class="page-description !mt-0" id="download-modal-message"></p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
            <a id="download-modal-readable" class="btn-primary hidden" href="#">@L("artifact.readable_text")</a>
            <a id="download-modal-ipa" class="btn-secondary hidden" href="#">@L("artifact.ipa")</a>
        </div>
        <div class="mt-6 flex items-center justify-end gap-3">
            <button type="button" class="btn-secondary" id="download-modal-close">@L("common.cancel")</button>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const page = document.getElementById("jobs-page");
            const confirmModal = document.getElementById("confirm-modal");
            const confirmModalTitle = document.getElementById("confirm-modal-title");
            const confirmModalMessage = document.getElementById("confirm-modal-message");
            const confirmModalInputWrap = document.getElementById("confirm-modal-input-wrap");
            const confirmModalInput = document.getElementById("confirm-modal-input");
            const confirmModalError = document.getElementById("confirm-modal-error");
            const confirmModalCancel = document.getElementById("confirm-modal-cancel");
            const confirmModalSubmit = document.getElementById("confirm-modal-submit");
            const downloadModal = document.getElementById("download-modal");
            const downloadModalMessage = document.getElementById("download-modal-message");
            const downloadModalReadable = document.getElementById("download-modal-readable");
            const downloadModalIpa = document.getElementById("download-modal-ipa");
            const downloadModalClose = document.getElementById("download-modal-close");

            const hasActive = page?.dataset.hasActive === "true";
            let activeForm = null;
            let activeExpected = null;
            let activeInvalidMessage = null;
            let restoreButton = null;

            window.addEventListener("pageshow", (event) => {
                if (event.persisted) {
                    location.reload();
                }
            });

            if (hasActive) {
                window.setInterval(() => location.reload(), 5000);
            }

            const closeModal = () => {
                confirmModal?.classList.add("hidden");
                confirmModalError?.classList.add("hidden");
                if (confirmModalError) {
                    confirmModalError.textContent = "";
                }
                if (confirmModalInput) {
                    confirmModalInput.value = "";
                }
                activeForm = null;
                activeExpected = null;
                activeInvalidMessage = null;
                restoreButton = null;
            };

            const openModal = (button, form) => {
                activeForm = form;
                activeExpected = button.dataset.confirmExpected || null;
                activeInvalidMessage = button.dataset.confirmInvalid || "";
                restoreButton = button;

                if (confirmModalTitle) {
                    confirmModalTitle.textContent = button.dataset.confirmTitle || "";
                }
                if (confirmModalMessage) {
                    confirmModalMessage.textContent = button.dataset.confirmMessage || "";
                }

                const needsText = button.dataset.confirmRequiresText === "true";
                confirmModalInputWrap?.classList.toggle("hidden", !needsText);
                confirmModalError?.classList.add("hidden");
                if (confirmModalError) {
                    confirmModalError.textContent = "";
                }
                if (confirmModalInput) {
                    confirmModalInput.value = "";
                }

                confirmModal?.classList.remove("hidden");
                if (needsText) {
                    window.setTimeout(() => confirmModalInput?.focus(), 0);
                } else {
                    window.setTimeout(() => confirmModalSubmit?.focus(), 0);
                }
            };

            document.querySelectorAll("form button[data-confirm-kind]").forEach((button) => {
                button.addEventListener("click", (event) => {
                    event.preventDefault();
                    const form = button.closest("form");
                    if (!form) {
                        return;
                    }
                    openModal(button, form);
                });
            });

            confirmModalCancel?.addEventListener("click", closeModal);
            confirmModal?.querySelectorAll("[data-modal-close='true']").forEach((element) => {
                element.addEventListener("click", closeModal);
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && confirmModal && !confirmModal.classList.contains("hidden")) {
                    closeModal();
                }
            });

            confirmModalSubmit?.addEventListener("click", () => {
                if (!activeForm) {
                    closeModal();
                    return;
                }

                if (activeExpected) {
                    const typed = (confirmModalInput?.value || "").trim();
                    if (typed !== activeExpected) {
                        if (confirmModalError) {
                            confirmModalError.textContent = activeInvalidMessage || "";
                            confirmModalError.classList.remove("hidden");
                        }
                        confirmModalInput?.focus();
                        return;
                    }

                    const confirmationInput = activeForm.querySelector("input[name='confirmation']");
                    if (confirmationInput instanceof HTMLInputElement) {
                        confirmationInput.value = typed;
                    }
                }

                const targetForm = activeForm;
                closeModal();
                targetForm.submit();
            });

            const downloadMessagePrefix = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("jobs.list.download_message_prefix")));

            const closeDownloadModal = () => {
                downloadModal?.classList.add("hidden");
                if (downloadModalMessage) {
                    downloadModalMessage.textContent = "";
                }
                if (downloadModalReadable) {
                    downloadModalReadable.classList.add("hidden");
                    downloadModalReadable.removeAttribute("href");
                }
                if (downloadModalIpa) {
                    downloadModalIpa.classList.add("hidden");
                    downloadModalIpa.removeAttribute("href");
                }
            };

            document.querySelectorAll("button[data-download-job-id]").forEach((button) => {
                button.addEventListener("click", () => {
                    const jobId = button.dataset.downloadJobId || "";
                    if (downloadModalMessage) {
                        downloadModalMessage.textContent = `${downloadMessagePrefix} ${jobId}`;
                    }

                    const readableUrl = button.dataset.downloadReadable || "";
                    const ipaUrl = button.dataset.downloadIpa || "";
                    if (downloadModalReadable) {
                        if (readableUrl) {
                            downloadModalReadable.setAttribute("href", readableUrl);
                            downloadModalReadable.classList.remove("hidden");
                        } else {
                            downloadModalReadable.classList.add("hidden");
                            downloadModalReadable.removeAttribute("href");
                        }
                    }
                    if (downloadModalIpa) {
                        if (ipaUrl) {
                            downloadModalIpa.setAttribute("href", ipaUrl);
                            downloadModalIpa.classList.remove("hidden");
                        } else {
                            downloadModalIpa.classList.add("hidden");
                            downloadModalIpa.removeAttribute("href");
                        }
                    }

                    downloadModal?.classList.remove("hidden");
                });
            });

            downloadModalClose?.addEventListener("click", closeDownloadModal);
            downloadModal?.querySelectorAll("[data-download-close='true']").forEach((element) => {
                element.addEventListener("click", closeDownloadModal);
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && downloadModal && !downloadModal.classList.contains("hidden")) {
                    closeDownloadModal();
                }
            });
        })();
    </script>
}
