@page "/setup"
@model TimelineForAudio.Web.Pages.SetupModel
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    Layout = "_SetupLayout";
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string StepClass(string step) => string.Equals(Model.Step, step, StringComparison.OrdinalIgnoreCase)
        ? "setup-step setup-step-active"
        : "setup-step";
    var gpuReady = Model.WorkerCapability.GpuAvailable && Model.WorkerCapability.DeviceNames.Count > 0;
    var detectedGpuLabel = gpuReady
        ? string.Join(", ", Model.WorkerCapability.DeviceNames)
        : L("settings.compute_mode.help_no_gpu_detected");
    var recommendedComputeMode = gpuReady ? "gpu" : "cpu";
    var recommendedComputeLabel = recommendedComputeMode == "gpu"
        ? L("settings.compute_mode.gpu")
        : L("settings.compute_mode.cpu");
    int StepNumberFor(string step) => step switch
    {
        "language" => 1,
        "compute" => 2,
        "account" => 3,
        "register" => 3,
        "token" => 4,
        "approval" => 5,
        "complete" => 5,
        _ => 1,
    };
    string StepTitleFor(string step) => step switch
    {
        "language" => L("setup.step.language"),
        "compute" => L("setup.step.compute"),
        "account" or "register" => L("setup.step.account"),
        "token" => L("setup.step.token"),
        "approval" => L("setup.step.approval"),
        "complete" => L("setup.complete.eyebrow"),
        _ => L("setup.step.language"),
    };
    var currentStepNumber = StepNumberFor(Model.Step);
    var progressPercent = Math.Clamp(currentStepNumber * 20, 20, 100);
    ViewData["Title"] = L("setup.page_title");
}

<section class="setup-page">
    <aside class="setup-rail">
        <div class="setup-rail-header space-y-3">
            <p class="setup-eyebrow">@L("setup.eyebrow")</p>
            <h1 class="setup-title">@L("setup.title")</h1>
            <p class="setup-description">@L("setup.description")</p>
        </div>

        <ol class="setup-steps">
            <li class="@StepClass("language")">@L("setup.step.language")</li>
            <li class="@StepClass("compute")">@L("setup.step.compute")</li>
            <li class="@StepClass("account")">@L("setup.step.account")</li>
            <li class="@StepClass("token")">@L("setup.step.token")</li>
            <li class="@StepClass("approval")">@L("setup.step.approval")</li>
        </ol>
    </aside>

    <section class="work-surface setup-work-surface">
        <section class="surface-status-strip setup-status-strip">
            <article class="surface-status-item">
                <span class="surface-status-label">@L("setup.step_label")</span>
                <strong class="surface-status-value">@currentStepNumber / 5</strong>
                <span class="surface-status-note">@StepTitleFor(Model.Step)</span>
            </article>
            <article class="surface-status-item">
                <span class="surface-status-label">@L("setup.eyebrow")</span>
                <strong class="surface-status-value">@progressPercent%</strong>
                <div class="surface-progress-bar">
                    <span style="width:@(progressPercent)%"></span>
                </div>
            </article>
        </section>

        @if (!ViewContext.ModelState.IsValid)
        {
            <section class="error-panel">
                <ul class="list-disc space-y-1 pl-5">
                    @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <section class="notice-panel">
                @Model.StatusMessage
            </section>
        }

        @if (Model.Step == "language")
        {
            <form method="post" asp-page-handler="Language" class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.step_label") 1</p>
                    <h2 class="section-title">@L("setup.language.title")</h2>
                </div>
                <div class="space-y-2">
                    <label class="metric-label" for="setup-language-select">@L("layout.language")</label>
                    <select id="setup-language-select" asp-for="UiLanguage" class="form-input w-full">
                        @foreach (var item in Model.SupportedLanguages)
                        {
                            <option value="@item.Code">@item.NativeName</option>
                        }
                    </select>
                </div>
                <div class="setup-actions">
                    <button class="btn-primary" type="submit">
                        <span>@L("common.next")</span>
                        @Html.AppIcon(AppIcons.Next, "ui-icon-sm")
                    </button>
                </div>
            </form>
        }

        @if (Model.Step == "compute")
        {
            <form method="post" asp-page-handler="Compute" class="setup-form">
                <div class="setup-header-row">
                    <div class="setup-section-header">
                        <p class="setup-eyebrow">@L("setup.step_label") 2</p>
                        <div class="flex items-center gap-2">
                            <h2 class="section-title">@L("setup.compute.title")</h2>
                            <button type="button"
                                    class="btn-icon"
                                    id="setup-gpu-help-open"
                                    data-twe-tooltip-ref
                                    data-twe-placement="top"
                                    aria-label="@L("settings.compute_mode.help_label")"
                                    title="@L("settings.compute_mode.help_label")">
                                @Html.AppIcon(AppIcons.Help, "ui-icon-sm")
                            </button>
                        </div>
                    </div>
                    <span class="badge-chip">@string.Format(L("settings.compute_mode.recommended"), recommendedComputeLabel)</span>
                </div>

                <div class="surface-block surface-block-muted text-sm text-slate-700 dark:text-slate-300">
                    <div class="font-medium text-slate-900 dark:text-slate-100">
                        @(gpuReady
                            ? string.Format(L("settings.compute_mode.gpu_ready"), detectedGpuLabel)
                            : L("settings.compute_mode.gpu_unavailable_note"))
                    </div>
                </div>

                <div class="grid gap-3 md:grid-cols-2">
                    <label class="twe-choice-card">
                        <input asp-for="ComputeMode"
                               type="radio"
                               value="cpu"
                               class="twe-choice-input" />
                        <span class="twe-choice-content">
                            <span class="twe-choice-title">@L("settings.compute_mode.cpu")</span>
                            <span class="twe-choice-note">@L("settings.compute_mode.cpu_note")</span>
                        </span>
                    </label>
                    <label class="twe-choice-card @(!gpuReady ? "twe-choice-card-disabled" : string.Empty)">
                        <input asp-for="ComputeMode"
                               type="radio"
                               value="gpu"
                               disabled="@(!gpuReady)"
                               class="twe-choice-input" />
                        <span class="twe-choice-content">
                            <span class="twe-choice-title">@L("settings.compute_mode.gpu")</span>
                            <span class="twe-choice-note">@L("settings.compute_mode.gpu_note")</span>
                        </span>
                    </label>
                </div>

                <div class="setup-actions">
                    <a class="btn-secondary" href="/setup?step=language">
                        @Html.AppIcon(AppIcons.Previous, "ui-icon-sm")
                        <span>@L("common.previous")</span>
                    </a>
                    <button class="btn-primary" type="submit">
                        <span>@L("common.next")</span>
                        @Html.AppIcon(AppIcons.Next, "ui-icon-sm")
                    </button>
                </div>
            </form>
        }

        @if (Model.Step == "account")
        {
            <form method="post" asp-page-handler="Account" class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.step_label") 3</p>
                    <h2 class="section-title">@L("setup.account.title")</h2>
                    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("setup.account.description")</p>
                </div>

                <div class="grid gap-3 md:grid-cols-2">
                    <button class="setup-choice-button" type="submit" name="answer" value="yes">
                        <span class="block font-medium">@L("setup.account.yes")</span>
                        <span class="block text-xs text-slate-500 dark:text-slate-400">@L("setup.account.yes_note")</span>
                    </button>
                    <button class="setup-choice-button" type="submit" name="answer" value="no">
                        <span class="block font-medium">@L("setup.account.no")</span>
                        <span class="block text-xs text-slate-500 dark:text-slate-400">@L("setup.account.no_note")</span>
                    </button>
                </div>

                <div class="setup-actions">
                    <a class="btn-secondary" href="/setup?step=compute">
                        @Html.AppIcon(AppIcons.Previous, "ui-icon-sm")
                        <span>@L("common.previous")</span>
                    </a>
                </div>
            </form>
        }

        @if (Model.Step == "register")
        {
            <form method="post" asp-page-handler="RegisterDone" class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.step_label") 3</p>
                    <h2 class="section-title">@L("setup.register.title")</h2>
                    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("setup.register.description")</p>
                </div>

                <a class="btn-primary w-fit"
                   href="@Model.HuggingFaceJoinUrl"
                   target="_blank"
                   rel="noreferrer">
                    @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                    <span>@L("setup.register.open")</span>
                </a>

                <div class="setup-actions">
                    <a class="btn-secondary" href="/setup?step=account">
                        @Html.AppIcon(AppIcons.Previous, "ui-icon-sm")
                        <span>@L("common.previous")</span>
                    </a>
                    <button class="btn-primary" type="submit">
                        <span>@L("setup.register.done")</span>
                        @Html.AppIcon(AppIcons.Next, "ui-icon-sm")
                    </button>
                </div>
            </form>
        }

        @if (Model.Step == "token")
        {
            <form method="post" asp-page-handler="Token" class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.step_label") 4</p>
                    <h2 class="section-title">@L("setup.token.title")</h2>
                    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("setup.token.description")</p>
                </div>

                <ol class="setup-guide-list">
                    <li class="setup-guide-list-item">@L("setup.token.guide_open")</li>
                    <li class="setup-guide-list-item">@L("setup.token.guide_create")</li>
                    <li class="setup-guide-list-item">@L("setup.token.guide_read")</li>
                    <li class="setup-guide-list-item">@L("setup.token.guide_name")</li>
                    <li class="setup-guide-list-item">@L("setup.token.guide_copy")</li>
                </ol>

                <div class="setup-link-row">
                    <a class="btn-secondary"
                       href="@Model.TokenSettingsUrl"
                       target="_blank"
                       rel="noreferrer">
                        @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                        <span>@L("setup.token.open")</span>
                    </a>
                </div>

                <div data-twe-input-wrapper-init class="twe-field">
                    <input id="setup-token-input"
                           asp-for="Token"
                           type="password"
                           class="twe-field-control"
                           placeholder="hf_..."
                           spellcheck="false"
                           autocomplete="off" />
                    <label class="twe-field-label" for="setup-token-input">@L("settings.token")</label>
                    <div data-twe-input-helper-ref class="twe-field-helper">@L("setup.token.security_note")</div>
                </div>

                <div class="setup-actions">
                    <a class="btn-secondary" href="/setup?step=account">
                        @Html.AppIcon(AppIcons.Previous, "ui-icon-sm")
                        <span>@L("common.previous")</span>
                    </a>
                    <button class="btn-primary" type="submit">
                        <span>@L("setup.token.verify")</span>
                        @Html.AppIcon(AppIcons.Next, "ui-icon-sm")
                    </button>
                </div>
            </form>
        }

        @if (Model.Step == "approval")
        {
            <form method="post" asp-page-handler="CheckApproval" class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.step_label") 5</p>
                    <h2 class="section-title">@L("setup.approval.title")</h2>
                    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("setup.approval.description")</p>
                </div>

                <a class="btn-primary w-fit"
                   href="@Model.PyannoteModelUrl"
                   target="_blank"
                   rel="noreferrer">
                    @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                    <span>@L("setup.approval.open")</span>
                </a>

                <div class="setup-actions">
                    <a class="btn-secondary" href="/setup?step=token">
                        @Html.AppIcon(AppIcons.Previous, "ui-icon-sm")
                        <span>@L("common.previous")</span>
                    </a>
                    <button class="btn-primary" type="submit">
                        <span>@L("setup.approval.check")</span>
                        @Html.AppIcon(AppIcons.Next, "ui-icon-sm")
                    </button>
                </div>
            </form>
        }

        @if (Model.Step == "complete")
        {
            <section class="setup-form">
                <div class="setup-section-header">
                    <p class="setup-eyebrow">@L("setup.complete.eyebrow")</p>
                    <h2 class="section-title">@L("setup.complete.title")</h2>
                    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("setup.complete.description")</p>
                </div>

                <div class="surface-block setup-success-note">
                    @L("setup.complete.status")
                </div>

                <div class="setup-actions">
                    <a class="btn-primary" href="/jobs/new">
                        @Html.AppIcon(AppIcons.NavNewJob, "ui-icon-sm")
                        <span>@L("setup.complete.new_job")</span>
                    </a>
                </div>
            </section>
        }
    </section>
</section>

<div id="setup-gpu-help-modal"
     class="modal-shell hidden"
     tabindex="-1"
     aria-hidden="true"
     data-twe-modal-init
     data-twe-class-backdrop="opacity-50 transition-all duration-200 ease-out fixed inset-0 z-[1040] bg-slate-950/45 backdrop-blur-sm"
     role="dialog"
     aria-modal="true"
     aria-labelledby="setup-gpu-help-modal-title">
    <div class="modal-card opacity-0 transition-opacity duration-200 ease-out" data-twe-modal-dialog-ref>
        <div class="space-y-4">
            <h2 class="section-title" id="setup-gpu-help-modal-title">@L("settings.compute_mode.help_title")</h2>
            <p class="page-description !mt-0">@L("settings.compute_mode.help_intro")</p>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300">
                <li class="modal-list-item">@L("settings.compute_mode.help_req_nvidia")</li>
                <li class="modal-list-item">@L("settings.compute_mode.help_req_docker")</li>
                <li class="modal-list-item">@L("settings.compute_mode.help_req_high")</li>
            </ul>
        </div>
        <div class="mt-6 flex flex-wrap justify-end gap-3">
            <button type="button" class="btn-secondary" id="setup-gpu-help-close" data-twe-modal-dismiss>@L("common.cancel")</button>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const gpuHelpOpen = document.getElementById("setup-gpu-help-open");
            const gpuHelpModal = document.getElementById("setup-gpu-help-modal");
            const modalApi = window.timelineForAudioModal;
            if (!gpuHelpModal) {
                return;
            }

            const closeGpuHelpModal = () => {
            };

            modalApi?.onHidden(gpuHelpModal, closeGpuHelpModal);
            gpuHelpOpen?.addEventListener("click", () => {
                modalApi?.show(gpuHelpModal, gpuHelpOpen);
            });
        })();
    </script>
}
