@page
@model ErrorModel
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    ViewData["Title"] = L("error.page_title");
}

<section class="space-y-6">
    <div class="work-surface">
        <h1 class="text-3xl font-semibold text-rose-700 dark:text-rose-300">@L("error.page_title")</h1>
        <h2 class="mt-2 text-base text-slate-700 dark:text-slate-300">@L("error.subtitle")</h2>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="surface-block text-sm text-slate-700 dark:text-slate-300">
            <strong>@L("error.request_id"):</strong> <code>@Model.RequestId</code>
        </div>
    }

    <div class="surface-block bg-amber-50 text-sm text-amber-950 dark:border-amber-500/30 dark:bg-amber-950/20 dark:text-amber-100">
        <h3 class="text-lg font-semibold">@L("error.development_mode")</h3>
        <p class="mt-3">@L("error.development_description")</p>
        <p class="mt-3">@L("error.development_warning")</p>
    </div>
</section>
