@page "/settings"
@model TimelineForAudio.Web.Pages.SettingsModel
@using TimelineForAudio.Web.Infrastructure
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    var languages = LanguageService.GetSupportedLanguages();
    string L(string key) => Localizer.Get(lang, key);
    string AccessLabel(string? value)
    {
        var key = $"access.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? L("access.unknown") : label;
    }

    string AccessBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "available" => "status-badge status-badge-neutral",
        "authorized" => "status-badge status-badge-success",
        "approval_required" => "status-badge status-badge-warning",
        "invalid_token" => "status-badge status-badge-danger",
        "token_missing" => "status-badge status-badge-warning",
        "consent_pending" => "status-badge status-badge-warning",
        "unauthorized" => "status-badge status-badge-warning",
        "unknown" => "status-badge status-badge-danger",
        _ => "status-badge status-badge-neutral",
    };

    string ConnectionBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "valid" => "status-badge status-badge-success",
        "cached" => "status-badge status-badge-success",
        "download_on_first_run" => "status-badge status-badge-neutral",
        "missing" => "status-badge status-badge-warning",
        "approval_required" => "status-badge status-badge-warning",
        "not_ready" => "status-badge status-badge-warning",
        "invalid" => "status-badge status-badge-danger",
        "token_check" => "status-badge status-badge-danger",
        "unknown" => "status-badge status-badge-danger",
        _ => "status-badge status-badge-neutral",
    };

    string FormatSize(long valueBytes)
    {
        if (valueBytes <= 0)
        {
            return "0 MB";
        }

        return valueBytes switch
        {
            >= 1024L * 1024L * 1024L => $"{valueBytes / 1024.0 / 1024.0 / 1024.0:F1} GB",
            _ => $"{valueBytes / 1024.0 / 1024.0:F1} MB",
        };
    }

    string ModelSavedSizeLabel(TimelineForAudio.Web.Models.GatedModelStatusItem model) =>
        model.SavedSizeBytes > 0
            ? DisplayFormatters.FormatFileSize(model.SavedSizeBytes, L)
            : L("settings.cache.empty_short");

    var accessState = (Model.Snapshot.AccessState ?? string.Empty).Trim().ToLowerInvariant();
    var gpuReady = Model.WorkerCapability.GpuAvailable && Model.WorkerCapability.DeviceNames.Count > 0;
    var detectedGpuLabel = gpuReady
        ? string.Join(", ", Model.WorkerCapability.DeviceNames)
        : L("settings.compute_mode.help_no_gpu_detected");
    var recommendedComputeMode = gpuReady ? "gpu" : "cpu";
    var recommendedComputeLabel = recommendedComputeMode == "gpu"
        ? L("settings.compute_mode.gpu")
        : L("settings.compute_mode.cpu");
    var autoSelectedNote = !Model.HasPersistedSettings
        ? string.Format(L("settings.compute_mode.auto_selected"), recommendedComputeLabel)
        : null;
    var pyannoteModel = Model.ModelStatuses.FirstOrDefault(static model => model.RequiresApproval)
        ?? new TimelineForAudio.Web.Models.GatedModelStatusItem();
    var modelCachedLocally = pyannoteModel.CachedLocally;
    var tokenState = accessState switch
    {
        "authorized" or "approval_required" => "valid",
        "invalid_token" => "invalid",
        "token_missing" => "missing",
        _ => "unknown",
    };
    var localModelState = modelCachedLocally
        ? "cached"
        : accessState switch
        {
            "authorized" => "download_on_first_run",
            "approval_required" => "approval_required",
            "invalid_token" => "token_check",
            "token_missing" => "not_ready",
            _ => "unknown",
        };
    var connectionHintKey = modelCachedLocally
        ? null
        : accessState switch
        {
            "authorized" => "settings.connection.hint_download",
            "approval_required" => "settings.connection.hint_approval",
            "invalid_token" => "settings.connection.hint_invalid_token",
            "token_missing" => "settings.connection.hint_token_missing",
            _ => "settings.connection.hint_unknown",
        };
    var showTokenAction = tokenState is "missing" or "invalid" or "unknown";
    var showApprovalAction = accessState == "approval_required" && !modelCachedLocally;
    var activeTokenPreview = !string.IsNullOrWhiteSpace(Model.Token)
        ? Model.DraftTokenPreview
        : Model.TokenPreview;
    var tokenActionLabel = !string.IsNullOrWhiteSpace(activeTokenPreview)
        ? L("settings.token_change")
        : L("settings.token_enter");
    ViewData["Title"] = L("settings.page_title");
}

<section class="app-page space-y-6">
    <header class="page-hero">
        <div>
            <h1 class="page-title">@L("settings.page_title")</h1>
        </div>
    </header>

    @if (!ViewContext.ModelState.IsValid)
    {
        <section class="panel error-panel">
            <ul class="list-disc space-y-1 pl-5">
                @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <form method="post" asp-page-handler="Save" class="space-y-6">
        <section class="work-surface settings-surface">
            <section class="settings-row">
                <div class="settings-row-header">
                    <div class="settings-row-copy">
                        <h2 class="section-title">@L("settings.language.heading")</h2>
                    </div>
                    <div class="settings-row-body settings-row-body-compact">
                        <label for="language-select" class="settings-label">@L("layout.language")</label>
                        <select id="language-select" asp-for="UiLanguage" class="form-input w-full">
                            @foreach (var item in languages)
                            {
                                <option value="@item.Code">@item.NativeName</option>
                            }
                        </select>
                    </div>
                </div>
            </section>

            <section class="settings-row">
                <div class="settings-row-header">
                    <div class="settings-row-copy">
                        <h2 class="section-title">@L("settings.theme.title")</h2>
                    </div>
                    <div class="settings-row-body">
                        <div class="theme-picker md:grid-cols-3">
                            <label class="twe-choice-card twe-choice-card-theme">
                                <span class="twe-choice-leading">
                                    <input asp-for="ThemeMode" type="radio" value="system" class="twe-choice-input" />
                                    <span class="twe-choice-title">@L("settings.theme.system")</span>
                                </span>
                                <div class="theme-preview theme-preview-system" aria-hidden="true">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </label>
                            <label class="twe-choice-card twe-choice-card-theme">
                                <span class="twe-choice-leading">
                                    <input asp-for="ThemeMode" type="radio" value="light" class="twe-choice-input" />
                                    <span class="twe-choice-title">@L("settings.theme.light")</span>
                                </span>
                                <div class="theme-preview theme-preview-light" aria-hidden="true">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </label>
                            <label class="twe-choice-card twe-choice-card-theme">
                                <span class="twe-choice-leading">
                                    <input asp-for="ThemeMode" type="radio" value="dark" class="twe-choice-input" />
                                    <span class="twe-choice-title">@L("settings.theme.dark")</span>
                                </span>
                                <div class="theme-preview theme-preview-dark" aria-hidden="true">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <section class="settings-row">
                <div class="settings-row-header">
                    <div class="settings-row-copy">
                        <div class="flex items-center gap-2">
                            <h2 class="section-title">@L("settings.compute_mode.title")</h2>
                            <button type="button"
                                    class="btn-icon"
                                    id="settings-gpu-help-open"
                                    data-twe-tooltip-ref
                                    data-twe-placement="top"
                                    aria-label="@L("settings.compute_mode.help_label")"
                                    title="@L("settings.compute_mode.help_label")">
                                @Html.AppIcon(AppIcons.Help, "ui-icon-sm")
                            </button>
                        </div>
                    </div>
                    <div class="settings-row-body">
                        <div class="flex flex-wrap gap-2">
                            <span class="badge-chip">@string.Format(L("settings.compute_mode.recommended"), recommendedComputeLabel)</span>
                        </div>
                        <div class="settings-inline-note">
                            <div class="settings-inline-note-title">
                                @(gpuReady
                                    ? string.Format(L("settings.compute_mode.gpu_ready"), detectedGpuLabel)
                                    : L("settings.compute_mode.gpu_unavailable_note"))
                            </div>
                            @if (!string.IsNullOrWhiteSpace(autoSelectedNote))
                            {
                                <div class="settings-inline-note-subtle">@autoSelectedNote</div>
                            }
                            @if (Model.SavedGpuPreferenceUnavailable)
                            {
                                <div class="settings-inline-note-warning">@L("settings.compute_mode.saved_gpu_unavailable")</div>
                            }
                        </div>
                        <div class="grid gap-3 md:grid-cols-2">
                            <label class="twe-choice-card">
                                <input asp-for="ComputeMode"
                                       type="radio"
                                       value="cpu"
                                       class="twe-choice-input" />
                                <span class="twe-choice-content">
                                    <span class="twe-choice-title">@L("settings.compute_mode.cpu")</span>
                                    <span class="twe-choice-note">@L("settings.compute_mode.cpu_note")</span>
                                </span>
                            </label>
                            <label class="twe-choice-card @(!gpuReady ? "twe-choice-card-disabled" : string.Empty)">
                                <input asp-for="ComputeMode"
                                       type="radio"
                                       value="gpu"
                                       disabled="@(!gpuReady)"
                                       class="twe-choice-input" />
                                <span class="twe-choice-content">
                                    <span class="twe-choice-title">@L("settings.compute_mode.gpu")</span>
                                    <span class="twe-choice-note">@L("settings.compute_mode.gpu_note")</span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <section class="settings-row">
                <div class="settings-row-header">
                    <div class="settings-row-copy">
                        <h2 class="section-title">@L("settings.connection.title")</h2>
                    </div>
                    <div class="settings-row-body">
                        <div class="flex flex-wrap gap-2">
                            <span class="@ConnectionBadgeClass(tokenState)">@L($"settings.connection.token_state.{tokenState}")</span>
                            <span class="@ConnectionBadgeClass(localModelState)">@L($"settings.connection.model_state.{localModelState}")</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(connectionHintKey))
                        {
                            <div class="settings-inline-note">
                                <div class="settings-inline-note-title">@L(connectionHintKey)</div>
                            </div>
                        }

                        <div class="space-y-2">
                            <div class="flex items-center justify-between gap-3">
                                <div class="settings-label">@L("settings.token")</div>
                                <span id="token-status-label"
                                      class="text-xs font-medium text-slate-500 dark:text-slate-400 @((Model.HasSavedTokenConfigured && string.IsNullOrWhiteSpace(Model.Token)) ? string.Empty : "hidden")">@L("settings.saved")</span>
                            </div>
                            <input id="token-input"
                                   name="Token"
                                   type="hidden"
                                   value="@Model.Token"
                                   data-saved-preview="@Model.TokenPreview"
                                   data-has-saved-token="@(Model.HasSavedTokenConfigured ? "true" : "false")"
                                   data-saved-label="@L("settings.saved")"
                                   data-not-saved-label="@L("settings.not_saved")"
                                   data-change-label="@L("settings.token_change")"
                                   data-enter-label="@L("settings.token_enter")" />
                            <div id="token-preview-panel" class="settings-token-summary">
                                <code id="token-preview-value"
                                      class="text-sm font-medium text-slate-900 dark:text-slate-100 @(string.IsNullOrWhiteSpace(activeTokenPreview) ? "hidden" : string.Empty)">@activeTokenPreview</code>
                                <span id="token-preview-empty"
                                      class="text-sm text-slate-500 dark:text-slate-400 @(!string.IsNullOrWhiteSpace(activeTokenPreview) ? "hidden" : string.Empty)">@L("settings.connection.token_state.missing")</span>
                                <button id="token-change-button" type="button" class="btn-secondary">@tokenActionLabel</button>
                            </div>
                        </div>

                        @if (showTokenAction || showApprovalAction)
                        {
                            <div class="flex flex-wrap gap-3">
                                @if (showTokenAction)
                                {
                                    <a class="btn-secondary"
                                       href="@Model.TokenSettingsUrl"
                                       target="_blank"
                                       rel="noreferrer">
                                        @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                                        <span>@L("settings.open_token")</span>
                                    </a>
                                }
                                @if (showApprovalAction)
                                {
                                    <a class="btn-secondary"
                                       href="@Model.PyannoteModelUrl"
                                       target="_blank"
                                       rel="noreferrer">
                                        @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                                        <span>@L("settings.open_approval")</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="settings-row">
                <button type="button"
                        class="settings-row-summary"
                        data-twe-collapse-init
                        data-twe-target="#settings-models-detail"
                        aria-expanded="false">
                    <div class="settings-row-copy">
                        <h2 class="section-title">@L("settings.models.details_title")</h2>
                    </div>
                    <span class="settings-row-summary-meta">
                        <span class="settings-row-summary-closed">@L("settings.models.show")</span>
                        <span class="settings-row-summary-open">@L("settings.models.hide")</span>
                        @Html.AppIcon(AppIcons.Expand, "ui-icon-sm")
                    </span>
                </button>
                <div id="settings-models-detail"
                     class="settings-row-detail hidden"
                     data-twe-collapse-item>
                    <div class="table-shell">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>@L("settings.models.model")</th>
                                    <th>@L("settings.models.purpose")</th>
                                    <th>@L("settings.models.saved_size")</th>
                                    <th>@L("settings.models.access")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gatedModel in Model.ModelStatuses)
                                {
                                    <tr>
                                        <td class="font-medium text-slate-900 dark:text-slate-100">
                                            @if (!string.IsNullOrWhiteSpace(gatedModel.ModelUrl))
                                            {
                                                <a class="hover:underline" href="@gatedModel.ModelUrl" target="_blank" rel="noreferrer">
                                                    @gatedModel.DisplayName
                                                </a>
                                            }
                                            else
                                            {
                                                @gatedModel.DisplayName
                                            }
                                        </td>
                                        <td>@gatedModel.Purpose</td>
                                        <td>@ModelSavedSizeLabel(gatedModel)</td>
                                        <td>
                                            <div class="flex flex-col items-start gap-2">
                                                <span class="@AccessBadgeClass(gatedModel.AccessState)">@AccessLabel(gatedModel.AccessState)</span>
                                                @if (gatedModel.RequiresApproval &&
                                                     !gatedModel.CachedLocally &&
                                                     !string.IsNullOrWhiteSpace(gatedModel.ApprovalUrl) &&
                                                    string.Equals(gatedModel.AccessState, "approval_required", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <a class="btn-table" href="@gatedModel.ApprovalUrl" target="_blank" rel="noreferrer">
                                                        @Html.AppIcon(AppIcons.OpenExternal, "ui-icon-sm")
                                                        <span>@L("settings.models.open")</span>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <div class="settings-action-row">
                <button class="btn-primary">
                    @Html.AppIcon(AppIcons.Save, "ui-icon-sm")
                    <span>@L("settings.save_button")</span>
                </button>
            </div>
        </section>
    </form>

    <section class="work-surface danger-zone">
        <div class="danger-zone-header">
            <h2 class="section-title">@L("settings.maintenance.title")</h2>
        </div>

        <div class="danger-row">
            <div class="danger-row-copy">
                <div class="danger-row-title">@L("settings.maintenance.cache_title")</div>
                <p class="page-description compact">@L("settings.maintenance.cache_description")</p>
                <dl class="danger-row-meta">
                    <div>
                        <dt>@L("settings.cache.saved_models")</dt>
                        <dd>@FormatSize(Model.ModelCache.TotalBytes)</dd>
                    </div>
                </dl>
            </div>
            <form method="post"
                  asp-page-handler="ClearModelCache"
                  data-confirm-title="@L("settings.maintenance.cache_title")"
                  data-confirm-message="@L("settings.maintenance.cache_confirm")"
                  data-confirm-submit-label="@L("settings.maintenance.cache_action")">
                <button class="btn-secondary" type="submit">
                    @Html.AppIcon(AppIcons.Delete, "ui-icon-sm")
                    <span>@L("settings.maintenance.cache_action")</span>
                </button>
            </form>
        </div>

        <div class="danger-row">
            <div class="danger-row-copy">
                <div class="danger-row-title">@L("settings.maintenance.jobs_title")</div>
                <p class="page-description compact">@L("settings.maintenance.jobs_description")</p>
                <dl class="danger-row-meta">
                    <div>
                        <dt>@L("settings.maintenance.jobs_count")</dt>
                        <dd>@Model.TotalRunCount</dd>
                    </div>
                </dl>
            </div>
            <form method="post"
                  asp-page-handler="DeleteAllJobs"
                  data-confirm-title="@L("settings.maintenance.jobs_title")"
                  data-confirm-message="@L("settings.maintenance.jobs_confirm")"
                  data-confirm-submit-label="@L("settings.maintenance.jobs_action")"
                  data-confirm-requires-text="true"
                  data-confirm-expected="DELETE"
                  data-confirm-invalid="@L("jobs.list.delete_all_invalid")">
                <input type="hidden" name="confirmation" />
                <button class="btn-table-danger" type="submit">
                    @Html.AppIcon(AppIcons.Delete, "ui-icon-sm")
                    <span>@L("settings.maintenance.jobs_action")</span>
                </button>
            </form>
        </div>

        <div class="danger-row">
            <div class="danger-row-copy">
                <div class="danger-row-title">@L("settings.maintenance.reset_title")</div>
                <p class="page-description compact">@L("settings.maintenance.reset_description_short")</p>
            </div>
            <form method="post"
                  asp-page-handler="ResetApp"
                  data-confirm-title="@L("settings.maintenance.reset_title")"
                  data-confirm-message="@L("settings.maintenance.reset_confirm")"
                  data-confirm-submit-label="@L("settings.maintenance.reset_action")"
                  data-confirm-requires-text="true"
                  data-confirm-expected="DELETE"
                  data-confirm-invalid="@L("jobs.list.delete_all_invalid")">
                <input type="hidden" name="confirmation" />
                <button class="btn-table-danger" type="submit">
                    @Html.AppIcon(AppIcons.Delete, "ui-icon-sm")
                    <span>@L("settings.maintenance.reset_action")</span>
                </button>
            </form>
        </div>
    </section>
</section>

<div id="settings-gpu-help-modal"
     class="modal-shell hidden"
     tabindex="-1"
     aria-hidden="true"
     data-twe-modal-init
     data-twe-class-backdrop="opacity-50 transition-all duration-200 ease-out fixed inset-0 z-[1040] bg-slate-950/45 backdrop-blur-sm"
     role="dialog"
     aria-modal="true"
     aria-labelledby="settings-gpu-help-modal-title">
    <div class="modal-card opacity-0 transition-opacity duration-200 ease-out" data-twe-modal-dialog-ref>
        <div class="space-y-4">
            <h2 class="section-title" id="settings-gpu-help-modal-title">@L("settings.compute_mode.help_title")</h2>
            <p class="page-description !mt-0">@L("settings.compute_mode.help_intro")</p>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300">
                <li class="modal-list-item">@L("settings.compute_mode.help_req_nvidia")</li>
                <li class="modal-list-item">@L("settings.compute_mode.help_req_docker")</li>
                <li class="modal-list-item">@L("settings.compute_mode.help_req_high")</li>
            </ul>
        </div>
        <div class="mt-6 flex flex-wrap justify-end gap-3">
            <button type="button" class="btn-secondary" id="settings-gpu-help-close" data-twe-modal-dismiss>@L("common.cancel")</button>
        </div>
    </div>
</div>

<div id="settings-token-modal"
     class="modal-shell @(Model.ShowTokenEditor ? string.Empty : "hidden")"
     tabindex="-1"
     aria-hidden="@(Model.ShowTokenEditor ? "false" : "true")"
     data-twe-modal-init
     data-twe-class-backdrop="opacity-50 transition-all duration-200 ease-out fixed inset-0 z-[1040] bg-slate-950/45 backdrop-blur-sm"
     role="dialog"
     aria-modal="true"
     aria-labelledby="settings-token-modal-title">
    <div class="modal-card opacity-0 transition-opacity duration-200 ease-out" data-twe-modal-dialog-ref>
        <div class="space-y-4">
            <h2 class="section-title" id="settings-token-modal-title">@L("settings.token")</h2>
            <div data-twe-input-wrapper-init class="twe-field">
                <input id="settings-token-modal-input"
                       type="text"
                       value="@Model.Token"
                       placeholder="hf_..."
                       class="twe-field-control"
                       spellcheck="false"
                       autocomplete="off" />
                <label class="twe-field-label" for="settings-token-modal-input">@L("settings.token")</label>
            </div>
        </div>
        <div class="mt-6 flex flex-wrap justify-end gap-3">
            <button type="button" class="btn-secondary" id="settings-token-modal-cancel" data-twe-modal-dismiss>@L("common.cancel")</button>
            <button type="button" class="btn-primary" id="settings-token-modal-submit">@L("settings.token_apply")</button>
        </div>
    </div>
</div>

<div id="settings-confirm-modal"
     class="modal-shell hidden"
     tabindex="-1"
     aria-hidden="true"
     data-twe-modal-init
     data-twe-class-backdrop="opacity-50 transition-all duration-200 ease-out fixed inset-0 z-[1040] bg-slate-950/45 backdrop-blur-sm"
     role="dialog"
     aria-modal="true"
     aria-labelledby="settings-confirm-modal-title">
    <div class="modal-card opacity-0 transition-opacity duration-200 ease-out" data-twe-modal-dialog-ref>
        <div class="space-y-4">
            <h2 class="section-title" id="settings-confirm-modal-title"></h2>
            <p class="page-description !mt-0" id="settings-confirm-modal-message"></p>
            <div id="settings-confirm-modal-input-wrap" class="hidden">
                <div data-twe-input-wrapper-init class="twe-field">
                    <input id="settings-confirm-modal-input"
                           type="text"
                           class="twe-field-control"
                           autocomplete="off"
                           spellcheck="false" />
                    <label class="twe-field-label" for="settings-confirm-modal-input">@L("common.confirm_text")</label>
                </div>
                <p id="settings-confirm-modal-error" class="mt-2 text-sm text-rose-700 dark:text-rose-300 hidden"></p>
            </div>
        </div>
        <div class="mt-6 flex flex-wrap justify-end gap-3">
            <button type="button" class="btn-secondary" id="settings-confirm-modal-cancel" data-twe-modal-dismiss>@L("common.cancel")</button>
            <button type="button" class="btn-table-danger" id="settings-confirm-modal-submit">@L("common.confirm")</button>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const modalApi = window.timelineForAudioModal;
            const gpuHelpOpen = document.getElementById("settings-gpu-help-open");
            const gpuHelpModal = document.getElementById("settings-gpu-help-modal");
            const tokenHiddenInput = document.getElementById("token-input");
            const tokenPreviewValue = document.getElementById("token-preview-value");
            const tokenPreviewEmpty = document.getElementById("token-preview-empty");
            const tokenChangeButton = document.getElementById("token-change-button");
            const tokenStatusLabel = document.getElementById("token-status-label");
            const tokenModal = document.getElementById("settings-token-modal");
            const tokenModalInput = document.getElementById("settings-token-modal-input");
            const tokenModalSubmit = document.getElementById("settings-token-modal-submit");
            const confirmModal = document.getElementById("settings-confirm-modal");
            const confirmModalTitle = document.getElementById("settings-confirm-modal-title");
            const confirmModalMessage = document.getElementById("settings-confirm-modal-message");
            const confirmModalInputWrap = document.getElementById("settings-confirm-modal-input-wrap");
            const confirmModalInput = document.getElementById("settings-confirm-modal-input");
            const confirmModalError = document.getElementById("settings-confirm-modal-error");
            const confirmModalSubmit = document.getElementById("settings-confirm-modal-submit");

            let activeForm = null;
            let activeExpected = null;
            let activeInvalidMessage = null;
            let lastFocusedElement = null;
            let tokenLastFocusedElement = null;

            const hasSavedTokenConfigured = tokenHiddenInput?.dataset.hasSavedToken === "true";
            const savedTokenPreview = tokenHiddenInput?.dataset.savedPreview || "";
            const savedTokenLabel = tokenHiddenInput?.dataset.savedLabel || "";
            const notSavedTokenLabel = tokenHiddenInput?.dataset.notSavedLabel || "";
            const tokenChangeLabel = tokenHiddenInput?.dataset.changeLabel || "";
            const tokenEnterLabel = tokenHiddenInput?.dataset.enterLabel || "";

            const maskTokenPreview = (value) => {
                const trimmed = (value || "").trim();
                if (!trimmed) {
                    return "";
                }

                if (trimmed.length <= 8) {
                    const visibleLength = Math.min(2, trimmed.length);
                    return `${trimmed.slice(0, visibleLength)}••••••••${trimmed.slice(trimmed.length - visibleLength)}`;
                }

                return `${trimmed.slice(0, 4)}••••••••${trimmed.slice(-4)}`;
            };

            const syncTokenSummary = () => {
                if (!tokenHiddenInput || !tokenPreviewValue || !tokenPreviewEmpty || !tokenChangeButton) {
                    return;
                }

                const draftValue = tokenHiddenInput.value.trim();
                const preview = draftValue
                    ? maskTokenPreview(draftValue)
                    : (hasSavedTokenConfigured ? savedTokenPreview : "");
                const hasPreview = preview.length > 0;

                tokenPreviewValue.textContent = preview;
                tokenPreviewValue.classList.toggle("hidden", !hasPreview);
                tokenPreviewEmpty.classList.toggle("hidden", hasPreview);
                tokenChangeButton.textContent = hasPreview ? tokenChangeLabel : tokenEnterLabel;

                if (tokenStatusLabel) {
                    if (draftValue) {
                        tokenStatusLabel.textContent = notSavedTokenLabel;
                        tokenStatusLabel.classList.remove("hidden");
                    } else if (hasSavedTokenConfigured) {
                        tokenStatusLabel.textContent = savedTokenLabel;
                        tokenStatusLabel.classList.remove("hidden");
                    } else {
                        tokenStatusLabel.classList.add("hidden");
                    }
                }
            };

            const closeTokenModal = () => {
                if (tokenModalInput && tokenHiddenInput) {
                    tokenModalInput.value = tokenHiddenInput.value;
                }
                if (tokenLastFocusedElement instanceof HTMLElement) {
                    tokenLastFocusedElement.focus();
                }
                tokenLastFocusedElement = null;
            };

            const openTokenModal = (trigger) => {
                if (!tokenModal || !tokenModalInput) {
                    return;
                }

                tokenLastFocusedElement = trigger;
                tokenModalInput.value = tokenHiddenInput?.value || "";
                modalApi?.show(tokenModal, trigger);
                window.setTimeout(() => tokenModalInput.focus(), 0);
            };

            const closeGpuHelpModal = () => {
            };

            modalApi?.onHidden(gpuHelpModal, closeGpuHelpModal);
            modalApi?.onHidden(tokenModal, closeTokenModal);

            gpuHelpOpen?.addEventListener("click", () => {
                modalApi?.show(gpuHelpModal, gpuHelpOpen);
            });

            tokenChangeButton?.addEventListener("click", () => openTokenModal(tokenChangeButton));
            tokenModalSubmit?.addEventListener("click", () => {
                if (!tokenHiddenInput || !tokenModalInput) {
                    modalApi?.hide(tokenModal);
                    return;
                }

                tokenHiddenInput.value = tokenModalInput.value.trim();
                syncTokenSummary();
                modalApi?.hide(tokenModal);
            });
            syncTokenSummary();
            if (tokenModal && !tokenModal.classList.contains("hidden")) {
                window.setTimeout(() => {
                    modalApi?.show(tokenModal);
                    tokenModalInput?.focus();
                }, 0);
            }

            const closeModal = () => {
                confirmModalInputWrap?.classList.add("hidden");
                confirmModalError?.classList.add("hidden");
                if (confirmModalInput) {
                    confirmModalInput.value = "";
                }
                if (confirmModalError) {
                    confirmModalError.textContent = "";
                }
                activeForm = null;
                activeExpected = null;
                activeInvalidMessage = null;
                if (lastFocusedElement instanceof HTMLElement) {
                    lastFocusedElement.focus();
                }
                lastFocusedElement = null;
            };

            modalApi?.onHidden(confirmModal, closeModal);

            const openModal = (form, trigger) => {
                if (!confirmModal || !confirmModalTitle || !confirmModalMessage || !confirmModalSubmit) {
                    form.submit();
                    return;
                }

                activeForm = form;
                activeExpected = form.getAttribute("data-confirm-expected");
                activeInvalidMessage = form.getAttribute("data-confirm-invalid") || "";
                lastFocusedElement = trigger;
                confirmModalTitle.textContent = form.getAttribute("data-confirm-title") || "";
                confirmModalMessage.textContent = form.getAttribute("data-confirm-message") || "";
                confirmModalSubmit.textContent = form.getAttribute("data-confirm-submit-label") || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("common.confirm")));
                const needsText = form.getAttribute("data-confirm-requires-text") === "true";
                confirmModalInputWrap?.classList.toggle("hidden", !needsText);
                confirmModalError?.classList.add("hidden");
                if (confirmModalInput) {
                    confirmModalInput.value = "";
                }
                modalApi?.show(confirmModal, trigger);
                window.setTimeout(() => {
                    if (needsText) {
                        confirmModalInput?.focus();
                        return;
                    }

                    confirmModalSubmit.focus();
                }, 0);
            };

            document.querySelectorAll("form[data-confirm-title] button[type='submit']").forEach((button) => {
                button.addEventListener("click", (event) => {
                    event.preventDefault();
                    const form = button.closest("form");
                    if (!form) {
                        return;
                    }

                    openModal(form, button);
                });
            });

            confirmModalSubmit?.addEventListener("click", () => {
                if (!activeForm) {
                    modalApi?.hide(confirmModal);
                    return;
                }

                if (activeExpected) {
                    const typed = (confirmModalInput?.value || "").trim();
                    if (typed !== activeExpected) {
                        if (confirmModalError) {
                            confirmModalError.textContent = activeInvalidMessage || "";
                            confirmModalError.classList.remove("hidden");
                        }
                        confirmModalInput?.focus();
                        return;
                    }

                    const confirmationInput = activeForm.querySelector("input[name='confirmation']");
                    if (confirmationInput instanceof HTMLInputElement) {
                        confirmationInput.value = typed;
                    }
                }

                const targetForm = activeForm;
                modalApi?.hide(confirmModal);
                targetForm.submit();
            });
        })();
    </script>
}
