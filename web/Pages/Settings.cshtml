@page "/settings"
@model TimelineForAudio.Web.Pages.SettingsModel
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    var languages = LanguageService.GetSupportedLanguages();
    string L(string key) => Localizer.Get(lang, key);
    string AccessLabel(string? value)
    {
        var key = $"access.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? L("access.unknown") : label;
    }

    string AccessBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "available" => "status-badge status-badge-neutral",
        "authorized" => "status-badge status-badge-success",
        "approval_required" => "status-badge status-badge-warning",
        "invalid_token" => "status-badge status-badge-danger",
        "token_missing" => "status-badge status-badge-warning",
        "consent_pending" => "status-badge status-badge-warning",
        "unauthorized" => "status-badge status-badge-warning",
        "unknown" => "status-badge status-badge-danger",
        _ => "status-badge status-badge-neutral",
    };

    string ConnectionBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "valid" => "status-badge status-badge-success",
        "cached" => "status-badge status-badge-success",
        "download_on_first_run" => "status-badge status-badge-neutral",
        "missing" => "status-badge status-badge-warning",
        "approval_required" => "status-badge status-badge-warning",
        "not_ready" => "status-badge status-badge-warning",
        "invalid" => "status-badge status-badge-danger",
        "token_check" => "status-badge status-badge-danger",
        "unknown" => "status-badge status-badge-danger",
        _ => "status-badge status-badge-neutral",
    };

    string FormatSize(long valueBytes)
    {
        if (valueBytes <= 0)
        {
            return "0 MB";
        }

        return valueBytes switch
        {
            >= 1024L * 1024L * 1024L => $"{valueBytes / 1024.0 / 1024.0 / 1024.0:F1} GB",
            _ => $"{valueBytes / 1024.0 / 1024.0:F1} MB",
        };
    }

    var accessState = (Model.Snapshot.AccessState ?? string.Empty).Trim().ToLowerInvariant();
    var gpuReady = Model.WorkerCapability.GpuAvailable && Model.WorkerCapability.DeviceNames.Count > 0;
    var detectedGpuLabel = gpuReady
        ? string.Join(", ", Model.WorkerCapability.DeviceNames)
        : L("settings.compute_mode.help_no_gpu_detected");
    var recommendedComputeMode = gpuReady ? "gpu" : "cpu";
    var recommendedComputeLabel = recommendedComputeMode == "gpu"
        ? L("settings.compute_mode.gpu")
        : L("settings.compute_mode.cpu");
    var autoSelectedNote = !Model.HasPersistedSettings
        ? string.Format(L("settings.compute_mode.auto_selected"), recommendedComputeLabel)
        : null;
    var pyannoteModel = Model.ModelStatuses.FirstOrDefault(static model => model.RequiresApproval)
        ?? new TimelineForAudio.Web.Models.GatedModelStatusItem();
    var modelCachedLocally = pyannoteModel.CachedLocally;
    var tokenState = accessState switch
    {
        "authorized" or "approval_required" => "valid",
        "invalid_token" => "invalid",
        "token_missing" => "missing",
        _ => "unknown",
    };
    var localModelState = modelCachedLocally
        ? "cached"
        : accessState switch
        {
            "authorized" => "download_on_first_run",
            "approval_required" => "approval_required",
            "invalid_token" => "token_check",
            "token_missing" => "not_ready",
            _ => "unknown",
        };
    var connectionHintKey = modelCachedLocally
        ? null
        : accessState switch
        {
            "authorized" => "settings.connection.hint_download",
            "approval_required" => "settings.connection.hint_approval",
            "invalid_token" => "settings.connection.hint_invalid_token",
            "token_missing" => "settings.connection.hint_token_missing",
            _ => "settings.connection.hint_unknown",
        };
    var showTokenAction = tokenState is "missing" or "invalid" or "unknown";
    var showApprovalAction = accessState == "approval_required" && !modelCachedLocally;
    ViewData["Title"] = L("settings.page_title");
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <h1 class="page-title">@L("settings.page_title")</h1>
        </div>
    </header>

    @if (!ViewContext.ModelState.IsValid)
    {
        <section class="panel error-panel">
            <ul class="list-disc space-y-1 pl-5">
                @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <form method="post" asp-page-handler="Save" class="space-y-6">
        <section class="panel space-y-4">
            <h2 class="section-title">@L("settings.language.heading")</h2>
            <div class="pt-1">
                <label for="language-select" class="mb-2 block text-sm font-medium text-slate-900">@L("layout.language")</label>
                <select id="language-select" asp-for="UiLanguage" class="form-input w-full">
                    @foreach (var item in languages)
                    {
                        <option value="@item.Code">@item.NativeName</option>
                    }
                </select>
            </div>
        </section>

        <section class="panel space-y-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <h2 class="section-title">@L("settings.compute_mode.title")</h2>
                <span class="badge-chip">@string.Format(L("settings.compute_mode.recommended"), recommendedComputeLabel)</span>
            </div>

            <div class="rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                <div class="font-medium text-slate-900">
                    @(gpuReady
                        ? string.Format(L("settings.compute_mode.gpu_ready"), detectedGpuLabel)
                        : L("settings.compute_mode.gpu_unavailable_note"))
                </div>
                @if (!string.IsNullOrWhiteSpace(autoSelectedNote))
                {
                    <div class="mt-2 text-xs text-slate-500">@autoSelectedNote</div>
                }
                @if (Model.SavedGpuPreferenceUnavailable)
                {
                    <div class="mt-2 text-xs text-amber-700">@L("settings.compute_mode.saved_gpu_unavailable")</div>
                }
            </div>

            <div class="grid gap-3 md:grid-cols-2">
                <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                    <input asp-for="ComputeMode"
                           type="radio"
                           value="cpu"
                           class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                    <span>
                        <span class="block font-medium text-slate-900">@L("settings.compute_mode.cpu")</span>
                        <span class="block text-xs text-slate-500">@L("settings.compute_mode.cpu_note")</span>
                    </span>
                </label>
                <label class="flex items-start gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700 @(!gpuReady ? "opacity-60 cursor-not-allowed" : "")">
                    <input asp-for="ComputeMode"
                           type="radio"
                           value="gpu"
                           disabled="@(!gpuReady)"
                           class="mt-1 h-4 w-4 border-slate-300 text-slate-900" />
                    <span>
                        <span class="block font-medium text-slate-900">@L("settings.compute_mode.gpu")</span>
                        <span class="block text-xs text-slate-500">@L("settings.compute_mode.gpu_note")</span>
                    </span>
                </label>
            </div>
        </section>

        <section class="panel space-y-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <h2 class="section-title">@L("settings.connection.title")</h2>
                <div class="flex flex-wrap gap-2">
                    <span class="@ConnectionBadgeClass(tokenState)">@L($"settings.connection.token_state.{tokenState}")</span>
                    <span class="@ConnectionBadgeClass(localModelState)">@L($"settings.connection.model_state.{localModelState}")</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(connectionHintKey))
            {
                <div class="rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4 text-sm text-slate-700">
                    <div class="font-medium text-slate-900">@L(connectionHintKey)</div>
                </div>
            }

            <div class="space-y-2">
                <div class="flex items-center justify-between gap-3">
                    <label class="text-sm font-medium text-slate-900" for="token-input">@L("settings.token")</label>
                    @if (Model.HasSavedTokenConfigured)
                    {
                        <span class="text-xs font-medium text-slate-500">@L("settings.saved")</span>
                    }
                </div>
                @if (Model.HasSavedTokenConfigured && !Model.ShowTokenEditor)
                {
                    <div id="token-preview-panel" class="flex flex-wrap items-center gap-3 rounded-[18px] border border-slate-200 bg-white/70 px-4 py-4">
                        <code class="text-sm font-medium text-slate-900">@Model.TokenPreview</code>
                        <button id="token-change-button" type="button" class="btn-secondary">@L("settings.token_change")</button>
                    </div>
                }
                <div id="token-editor-panel" class="@(Model.HasSavedTokenConfigured && !Model.ShowTokenEditor ? "hidden" : string.Empty)">
                    <input id="token-input"
                           name="Token"
                           type="text"
                           value="@Model.Token"
                           placeholder="hf_..."
                           class="form-input token-input"
                           spellcheck="false"
                           autocomplete="off" />
                </div>
            </div>

            @if (showTokenAction || showApprovalAction)
            {
                <div class="flex flex-wrap gap-3">
                    @if (showTokenAction)
                    {
                        <a class="btn-secondary"
                           href="@Model.TokenSettingsUrl"
                           target="_blank"
                           rel="noreferrer">
                            @L("settings.open_token")
                        </a>
                    }
                    @if (showApprovalAction)
                    {
                        <a class="btn-secondary"
                           href="@Model.PyannoteModelUrl"
                           target="_blank"
                           rel="noreferrer">
                            @L("settings.open_approval")
                        </a>
                    }
                </div>
            }
        </section>

        <details class="panel subtle-panel group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
                <div>
                    <h2 class="section-title">@L("settings.models.details_title")</h2>
                </div>
                <span class="text-sm text-slate-500 group-open:hidden">@L("settings.models.show")</span>
                <span class="text-sm text-slate-500 hidden group-open:inline">@L("settings.models.hide")</span>
            </summary>
            <div class="mt-4 table-shell">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>@L("settings.models.model")</th>
                            <th>@L("settings.models.purpose")</th>
                            <th>@L("settings.models.access")</th>
                            <th>@L("common.actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var gatedModel in Model.ModelStatuses)
                        {
                            <tr>
                                <td class="font-medium text-slate-900">
                                    @if (!string.IsNullOrWhiteSpace(gatedModel.ModelUrl))
                                    {
                                        <a class="hover:underline" href="@gatedModel.ModelUrl" target="_blank" rel="noreferrer">
                                            @gatedModel.DisplayName
                                        </a>
                                    }
                                    else
                                    {
                                        @gatedModel.DisplayName
                                    }
                                </td>
                                <td>@gatedModel.Purpose</td>
                                <td>
                                    <span class="@AccessBadgeClass(gatedModel.AccessState)">@AccessLabel(gatedModel.AccessState)</span>
                                </td>
                                <td>
                                    @if (gatedModel.RequiresApproval &&
                                         !gatedModel.CachedLocally &&
                                         !string.IsNullOrWhiteSpace(gatedModel.ApprovalUrl) &&
                                         string.Equals(gatedModel.AccessState, "approval_required", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a class="btn-table" href="@gatedModel.ApprovalUrl" target="_blank" rel="noreferrer">
                                            @L("settings.models.open")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-slate-500">@L("settings.models.no_action")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>

        <div class="flex flex-wrap items-center gap-3">
            <button class="btn-primary">@L("settings.save_button")</button>
        </div>
    </form>

    <section class="panel space-y-4">
        <h2 class="section-title">@L("settings.maintenance.title")</h2>

        <div class="grid gap-4 lg:grid-cols-2">
            <div class="panel subtle-panel space-y-4">
                <div class="font-medium text-slate-900">@L("settings.maintenance.cache_title")</div>
                <p class="text-sm leading-7 text-slate-600">@L("settings.maintenance.cache_description")</p>
                <dl class="grid gap-2 text-sm text-slate-700">
                    <div>
                        <dt class="text-slate-500">@L("settings.cache.saved_models")</dt>
                        <dd>@FormatSize(Model.ModelCache.TotalBytes)</dd>
                    </div>
                </dl>
                <form method="post"
                      asp-page-handler="ClearModelCache"
                      data-confirm-title="@L("settings.maintenance.cache_title")"
                      data-confirm-message="@L("settings.maintenance.cache_confirm")"
                      data-confirm-submit-label="@L("settings.maintenance.cache_action")">
                    <button class="btn-secondary" type="submit">@L("settings.maintenance.cache_action")</button>
                </form>
            </div>

            <div class="panel subtle-panel space-y-4">
                <div>
                    <div class="font-medium text-slate-900">@L("settings.maintenance.reset_title")</div>
                    <p class="mt-2 text-sm leading-7 text-slate-600">@L("settings.maintenance.reset_description_short")</p>
                </div>
                <form method="post"
                      asp-page-handler="ResetApp"
                      data-confirm-title="@L("settings.maintenance.reset_title")"
                      data-confirm-message="@L("settings.maintenance.reset_confirm")"
                      data-confirm-submit-label="@L("settings.maintenance.reset_action")">
                    <button class="btn-table-danger" type="submit">@L("settings.maintenance.reset_action")</button>
                </form>
            </div>
        </div>
    </section>
</section>

<div id="settings-confirm-modal"
     class="modal-shell hidden"
     role="dialog"
     aria-modal="true"
     aria-labelledby="settings-confirm-modal-title">
    <div class="modal-backdrop" data-settings-modal-close="true"></div>
    <div class="modal-card">
        <div class="space-y-4">
            <h2 class="section-title" id="settings-confirm-modal-title"></h2>
            <p class="page-description !mt-0" id="settings-confirm-modal-message"></p>
        </div>
        <div class="mt-6 flex flex-wrap justify-end gap-3">
            <button type="button" class="btn-secondary" id="settings-confirm-modal-cancel">@L("common.cancel")</button>
            <button type="button" class="btn-table-danger" id="settings-confirm-modal-submit">@L("common.confirm")</button>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const input = document.getElementById("token-input");
            const previewPanel = document.getElementById("token-preview-panel");
            const editorPanel = document.getElementById("token-editor-panel");
            const changeButton = document.getElementById("token-change-button");
            const confirmModal = document.getElementById("settings-confirm-modal");
            const confirmModalTitle = document.getElementById("settings-confirm-modal-title");
            const confirmModalMessage = document.getElementById("settings-confirm-modal-message");
            const confirmModalCancel = document.getElementById("settings-confirm-modal-cancel");
            const confirmModalSubmit = document.getElementById("settings-confirm-modal-submit");

            let activeForm = null;
            let lastFocusedElement = null;

            if (input && previewPanel && editorPanel && changeButton) {
                changeButton.addEventListener("click", () => {
                    previewPanel.classList.add("hidden");
                    editorPanel.classList.remove("hidden");
                    window.requestAnimationFrame(() => input.focus());
                });
            }

            const closeModal = () => {
                confirmModal?.classList.add("hidden");
                activeForm = null;
                if (lastFocusedElement instanceof HTMLElement) {
                    lastFocusedElement.focus();
                }
                lastFocusedElement = null;
            };

            const openModal = (form, trigger) => {
                if (!confirmModal || !confirmModalTitle || !confirmModalMessage || !confirmModalSubmit) {
                    form.submit();
                    return;
                }

                activeForm = form;
                lastFocusedElement = trigger;
                confirmModalTitle.textContent = form.getAttribute("data-confirm-title") || "";
                confirmModalMessage.textContent = form.getAttribute("data-confirm-message") || "";
                confirmModalSubmit.textContent = form.getAttribute("data-confirm-submit-label") || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("common.confirm")));
                confirmModal.classList.remove("hidden");
                window.setTimeout(() => confirmModalSubmit.focus(), 0);
            };

            document.querySelectorAll("form[data-confirm-title] button[type='submit']").forEach((button) => {
                button.addEventListener("click", (event) => {
                    event.preventDefault();
                    const form = button.closest("form");
                    if (!form) {
                        return;
                    }

                    openModal(form, button);
                });
            });

            confirmModalCancel?.addEventListener("click", closeModal);
            confirmModal?.querySelectorAll("[data-settings-modal-close='true']").forEach((element) => {
                element.addEventListener("click", closeModal);
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && confirmModal && !confirmModal.classList.contains("hidden")) {
                    closeModal();
                }
            });

            confirmModalSubmit?.addEventListener("click", () => {
                if (!activeForm) {
                    closeModal();
                    return;
                }

                const targetForm = activeForm;
                closeModal();
                targetForm.submit();
            });
        })();
    </script>
}
