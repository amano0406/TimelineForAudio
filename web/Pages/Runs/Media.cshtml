@page "/jobs/{jobId}/{mediaId}"
@model TimelineForAudio.Web.Pages.Runs.MediaModel
@using System
@using TimelineForAudio.Web.Infrastructure
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string StateLabel(string? value)
    {
        var key = $"state.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }
    string StateBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "running" => "status-badge status-badge-info",
        "pending" => "status-badge status-badge-warning",
        "completed" => "status-badge status-badge-success",
        "failed" => "status-badge status-badge-danger",
        "canceled" => "status-badge status-badge-neutral",
        _ => "status-badge status-badge-neutral",
    };
    string ArtifactLabel(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "ipa" => L("artifact.ipa"),
        "readable_text" or "readable-text" => L("artifact.readable_text"),
        _ => value ?? "-",
    };
    string SpeakerStatusLabel(string? value)
    {
        var key = $"speaker_status.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }
    string? SpeakerStatusHint(string? value)
    {
        return string.Equals(value, "estimated", StringComparison.OrdinalIgnoreCase)
            ? SpeakerStatusLabel(value)
            : null;
    }
    string ArtifactUrl(string mediaId, string artifactKind) => $"/jobs/{Uri.EscapeDataString(Model.JobId)}/{Uri.EscapeDataString(mediaId)}?artifact={Uri.EscapeDataString(artifactKind)}";
    string SelectedArtifactUrl(string artifactKind) => ArtifactUrl(Model.MediaId, artifactKind);
    ViewData["Title"] = L("media.page_title");
}

<section class="app-page space-y-6">
    <div class="page-hero">
        <div>
            <p class="eyebrow">@L("media.run")</p>
            <h1 class="page-title">@Model.FileName</h1>
            <p class="page-description">
                @L("common.job"):
                <a class="text-sky-700 hover:text-sky-500 dark:text-sky-300 dark:hover:text-sky-200" href="@JobUrls.Details(Model.JobId)">@Model.JobId</a>
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
                @if (Model.HasReadableTextArtifact)
                {
                    <a class="@(string.Equals(Model.SelectedArtifactKind, "readable-text", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-secondary")"
                       href="@SelectedArtifactUrl("readable-text")">@L("artifact.readable_text")</a>
                }
                @if (Model.HasIpaArtifact)
                {
                    <a class="@(string.Equals(Model.SelectedArtifactKind, "ipa", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-secondary")"
                       href="@SelectedArtifactUrl("ipa")">@L("artifact.ipa")</a>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.SpeakerCountNote))
            {
                <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">@Model.SpeakerCountNote</p>
            }
        </div>
        <div class="flex items-center gap-3">
            <a class="btn-secondary" href="@JobUrls.Details(Model.JobId)">@L("media.back_to_job_details")</a>
            <details class="action-menu" data-action-menu>
                <summary class="action-menu-summary"
                         aria-label="@L("common.more_actions")"
                         title="@L("common.more_actions")">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <circle cx="12" cy="5" r="1.8"></circle>
                        <circle cx="12" cy="12" r="1.8"></circle>
                        <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                </summary>
                <div class="action-menu-panel" role="menu">
                    <button type="button"
                            class="action-menu-item"
                            data-copy-source="artifact-raw-markdown"
                            data-copy-label="@L("common.copy_markdown")"
                            data-copy-done="@L("common.copy_done")"
                            data-copy-failed="@L("common.copy_failed")"
                            aria-label="@L("common.copy_markdown")"
                            title="@L("common.copy_markdown")">
                        <span class="copy-icon copy-icon-default" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                                <path d="M7 15H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v1"></path>
                            </svg>
                        </span>
                        <span class="copy-icon copy-icon-success" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6 9 17l-5-5"></path>
                            </svg>
                        </span>
                        <span>@L("common.copy_markdown")</span>
                        <span class="sr-only" data-copy-feedback aria-live="polite"></span>
                    </button>
                    <a class="action-menu-item"
                       data-menu-close="true"
                       href="@JobUrls.MediaMarkdown(Model.JobId, Model.MediaId, Model.SelectedArtifactKind)"
                       download>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3v12"></path>
                            <path d="m7 10 5 5 5-5"></path>
                            <path d="M5 21h14"></path>
                        </svg>
                        <span>@L("common.download_markdown")</span>
                    </a>
                </div>
            </details>
        </div>
    </div>

    <section class="surface-status-strip">
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("details.primary_artifact")</div>
            <div class="surface-status-value">@ArtifactLabel(Model.SelectedArtifactKind)</div>
        </div>
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("details.speakers")</div>
            <div class="surface-status-value">@(Model.SpeakerCount?.ToString() ?? "-")</div>
            @if (!string.IsNullOrWhiteSpace(SpeakerStatusHint(Model.SpeakerCountStatus)))
            {
                <div class="surface-status-note">@SpeakerStatusHint(Model.SpeakerCountStatus)</div>
            }
        </div>
        <div class="surface-status-chip">
            <div class="surface-status-label">@L("media.turn_groups")</div>
            <div class="surface-status-value">@Model.PreviewGroupCount</div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[minmax(280px,0.78fr)_minmax(0,1.22fr)]">
        <div class="work-surface">
            <div class="job-list-header">
                <h2 class="section-title">@L("media.artifact_list")</h2>
                <span class="badge-chip">@Model.JobArtifacts.Count</span>
            </div>
            <div class="data-list artifact-rail-list mt-5">
                @foreach (var item in Model.JobArtifacts)
                {
                    <article class="artifact-rail-item @(item.IsCurrent ? "artifact-rail-item-current" : string.Empty)">
                        <div class="data-row-main">
                            <div class="data-row-title-line">
                                <div class="data-row-title">@item.FileName</div>
                                @if (item.IsCurrent)
                                {
                                    <span class="badge-chip">@L("media.current_item")</span>
                                }
                            </div>
                            <div class="data-row-meta">
                                <span class="@StateBadgeClass(item.Status)">@StateLabel(item.Status)</span>
                                <span>@($"{L("details.speakers")}: {(item.SpeakerCount?.ToString() ?? "-")}")</span>
                            </div>
                        </div>
                        <div class="data-row-actions">
                            @if (item.HasReadableTextArtifact)
                            {
                                <a class="@(item.IsCurrent && string.Equals(Model.SelectedArtifactKind, "readable-text", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-table")"
                                   href="@ArtifactUrl(item.MediaId, "readable-text")">@L("artifact.readable_text")</a>
                            }
                            @if (item.HasIpaArtifact)
                            {
                                <a class="@(item.IsCurrent && string.Equals(Model.SelectedArtifactKind, "ipa", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-table")"
                                   href="@ArtifactUrl(item.MediaId, "ipa")">IPA</a>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="work-surface document-surface">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="section-title">@L("media.preview_title")</h2>
                <span class="badge-chip">@ArtifactLabel(Model.SelectedArtifactKind)</span>
            </div>
            @if (Model.PreviewBlocks.Count == 0)
            {
                <div class="empty-state mt-6">@L("media.preview_empty")</div>
            }
            else
            {
                <div class="artifact-document mt-6">
                    @foreach (var block in Model.PreviewBlocks)
                    {
                        <article class="artifact-document-block">
                            <div class="artifact-document-speaker">@block.Speaker</div>
                            @if (block.IsIpa)
                            {
                                <pre class="artifact-document-content artifact-document-content-ipa">@block.Content</pre>
                            }
                            else
                            {
                                <div class="artifact-document-content">@block.Content</div>
                            }
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <pre id="artifact-raw-markdown" class="sr-only" hidden>@Model.ArtifactText</pre>
</section>
