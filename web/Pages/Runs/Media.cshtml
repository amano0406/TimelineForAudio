@page "/jobs/{jobId}/{mediaId}"
@model TimelineForAudio.Web.Pages.Runs.MediaModel
@using System
@using TimelineForAudio.Web.Infrastructure
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string ArtifactLabel(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "ipa" => L("artifact.ipa"),
        "readable_text" or "readable-text" => L("artifact.readable_text"),
        _ => value ?? "-",
    };
    string SpeakerStatusLabel(string? value)
    {
        var key = $"speaker_status.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }
    string ArtifactUrl(string artifactKind) => $"/jobs/{Uri.EscapeDataString(Model.JobId)}/{Uri.EscapeDataString(Model.MediaId)}?artifact={Uri.EscapeDataString(artifactKind)}";
    ViewData["Title"] = L("media.page_title");
}

<section class="app-page space-y-6">
    <div class="panel page-header">
        <div>
            <h1 class="page-title">@Model.FileName</h1>
            <p class="page-description">
                @L("common.job"):
                <a class="text-sky-700 hover:text-sky-500" href="@JobUrls.Details(Model.JobId)">@Model.JobId</a>
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
                @if (Model.HasReadableTextArtifact)
                {
                    <a class="@(string.Equals(Model.SelectedArtifactKind, "readable-text", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-secondary")"
                       href="@ArtifactUrl("readable-text")">@L("artifact.readable_text")</a>
                }
                @if (Model.HasIpaArtifact)
                {
                    <a class="@(string.Equals(Model.SelectedArtifactKind, "ipa", StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-secondary")"
                       href="@ArtifactUrl("ipa")">@L("artifact.ipa")</a>
                }
            </div>
            <dl class="mt-3 grid gap-2 text-sm text-slate-600 md:grid-cols-2">
                <div>
                    <dt class="text-slate-500">@L("details.primary_artifact")</dt>
                    <dd>@ArtifactLabel(Model.SelectedArtifactKind)</dd>
                </div>
                <div>
                    <dt class="text-slate-500">@L("details.speakers")</dt>
                    <dd>
                        @(Model.SpeakerCount?.ToString() ?? "-")
                        @if (!string.IsNullOrWhiteSpace(Model.SpeakerCountStatus))
                        {
                            <span class="ml-2 text-xs text-slate-500">@SpeakerStatusLabel(Model.SpeakerCountStatus)</span>
                        }
                    </dd>
                </div>
            </dl>
            @if (!string.IsNullOrWhiteSpace(Model.SpeakerCountNote))
            {
                <p class="mt-3 text-xs text-slate-500">@Model.SpeakerCountNote</p>
            }
        </div>
        <a class="btn-secondary" href="@JobUrls.Details(Model.JobId)">@L("media.back_to_job_details")</a>
    </div>

    @if (Model.PreviewBlocks.Count > 0)
    {
        <section class="panel">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="section-title">@L("media.preview_title")</h2>
                <span class="badge-chip">@ArtifactLabel(Model.SelectedArtifactKind)</span>
            </div>
            <div class="conversation-thread mt-6">
                @foreach (var block in Model.PreviewBlocks)
                {
                    <div class="conversation-row @(string.Equals(block.Alignment, "right", StringComparison.OrdinalIgnoreCase) ? "conversation-row-right" : string.Empty)">
                        <article class="conversation-bubble @(block.IsIpa ? "conversation-bubble-ipa" : string.Empty)">
                            <div class="conversation-speaker">@block.Speaker</div>
                            @if (block.IsIpa)
                            {
                                <pre class="conversation-text conversation-code">@block.Content</pre>
                            }
                            else
                            {
                                <div class="conversation-text">@block.Content</div>
                            }
                        </article>
                    </div>
                }
            </div>
        </section>
    }

    <details class="panel subtle-panel group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
            <h2 class="section-title">@L("media.raw_markdown")</h2>
        </summary>
        <div class="mt-4 timeline-shell">
            <pre class="text-sm leading-7 text-slate-100">@Model.ArtifactText</pre>
        </div>
    </details>
</section>
