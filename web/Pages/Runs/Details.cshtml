@page "/jobs/{id}"
@model TimelineForAudio.Web.Pages.Runs.DetailsModel
@using System.IO
@using TimelineForAudio.Web.Infrastructure
@using TimelineForAudio.Web.Models
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var run = Model.Run!;
    var status = run.Status;
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string StateLabel(string? value)
    {
        var key = $"state.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string StageLabel(string? value)
    {
        if (string.Equals(value, "skipped_duplicate", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.cache_reused");
        }
        if (string.Equals(value, "skipped_invalid", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.skipped_invalid");
        }
        if (string.Equals(value, "skipped_too_short", StringComparison.OrdinalIgnoreCase))
        {
            return L("details.skipped_too_short");
        }

        var key = $"stage.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string? SecondaryStageLabel(string? state, string? stage)
    {
        if (string.IsNullOrWhiteSpace(stage) ||
            string.Equals(stage, state, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var label = StageLabel(stage);
        return label == "-" ? null : label;
    }

    string SpeakerStatusLabel(string? value)
    {
        var key = $"speaker_status.{(value ?? string.Empty).ToLowerInvariant()}";
        var label = L(key);
        return label == key ? value ?? "-" : label;
    }

    string StateBadgeClass(string? value) => (value ?? string.Empty).ToLowerInvariant() switch
    {
        "running" => "status-badge status-badge-info",
        "pending" => "status-badge status-badge-warning",
        "completed" => "status-badge status-badge-success",
        "failed" => "status-badge status-badge-danger",
        "canceled" => "status-badge status-badge-neutral",
        _ => "status-badge status-badge-neutral",
    };

    int CompletedCount(JobStatusDocument? source) =>
        (source?.VideosDone ?? 0) + (source?.VideosSkipped ?? 0) + (source?.VideosFailed ?? 0);

    double Percent(double? raw, int completed, int total)
    {
        if (raw.HasValue && raw.Value > 0)
        {
            return Math.Clamp(raw.Value, 0, 100);
        }

        return total <= 0 ? 0 : Math.Round(completed * 100.0 / total, 1);
    }

    string PercentLabel(double value) => $"{Math.Round(value, 1):0.0}%";
    string FormatDurationFriendly(double? seconds) => DisplayFormatters.FormatDurationFriendly(seconds, L);
    string FormatDurationOrDash(double? seconds) => seconds.HasValue ? FormatDurationFriendly(seconds) : "-";
    string ItemStatusLabel(string? value)
    {
        var normalized = (value ?? string.Empty).ToLowerInvariant();
        return normalized switch
        {
            "pending" or "running" or "completed" or "failed" or "canceled" => StateLabel(normalized),
            "skipped_duplicate" => L("details.cache_reused"),
            "skipped_invalid" => L("details.skipped_invalid"),
            "skipped_too_short" => L("details.skipped_too_short"),
            _ => StageLabel(normalized),
        };
    }

    string DisplayFileName(MediaArtifactItem item) =>
        !string.IsNullOrWhiteSpace(item.FileName)
            ? item.FileName
            : System.IO.Path.GetFileName(item.SourcePath ?? item.MediaId);
    string ArtifactUrl(MediaArtifactItem item, string artifactKind) =>
        $"{JobUrls.Media(run.JobId, item.MediaId)}?artifact={Uri.EscapeDataString(artifactKind)}";

    ViewData["Title"] = L("details.page_title");
    var progressPercent = Percent(status?.ProgressPercent, CompletedCount(status), status?.VideosTotal ?? 0);
    var isActive = string.Equals(status?.State, "pending", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(status?.State, "running", StringComparison.OrdinalIgnoreCase);
    var canDownloadReadableTextArchive = !isActive && run.ArtifactItems.Any(item => !string.IsNullOrWhiteSpace(item.ReadableTextPath));
    var canDownloadIpaArchive = !isActive && run.ArtifactItems.Any(item => !string.IsNullOrWhiteSpace(item.IpaPath));
    var hasDownloadableArchive = canDownloadReadableTextArchive || canDownloadIpaArchive;
    var currentFileElapsed = string.IsNullOrWhiteSpace(status?.CurrentMedia)
        ? "-"
        : FormatDurationFriendly(status?.CurrentMediaElapsedSec);
    var headerStageLabel = SecondaryStageLabel(status?.State, status?.CurrentStage);
    var skippedItems = run.Manifest?.Items
        .Where(item => string.Equals(item.Status, "skipped_invalid", StringComparison.OrdinalIgnoreCase) ||
                       string.Equals(item.Status, "skipped_too_short", StringComparison.OrdinalIgnoreCase))
        .ToList() ?? [];
}

<section class="app-page space-y-6" data-active="@(isActive ? "true" : "false")" id="job-details">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <div class="panel page-header">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-2">
                <h1 class="page-title">@run.JobId</h1>
                <div class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
                    <span class="@StateBadgeClass(status?.State)">@StateLabel(status?.State)</span>
                    @if (!string.IsNullOrWhiteSpace(headerStageLabel))
                    {
                        <span>@headerStageLabel</span>
                    }
                </div>
            </div>
            @if (hasDownloadableArchive)
            {
                <button type="button"
                        class="btn-secondary"
                        id="details-download-button"
                        data-download-job-id="@run.JobId"
                        data-download-readable="@(canDownloadReadableTextArchive ? JobUrls.Download(run.JobId, "readable-text") : "")"
                        data-download-ipa="@(canDownloadIpaArchive ? JobUrls.Download(run.JobId, "ipa") : "")">
                    @L("details.download_zip")
                </button>
            }
        </div>
    </div>

    <section class="grid gap-4 lg:grid-cols-4">
        <div class="metric-card">
            <div class="metric-label">@L("common.state")</div>
            <div class="metric-value">
                <span class="@StateBadgeClass(status?.State)">@StateLabel(status?.State)</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(headerStageLabel))
            {
                <div class="metric-subtle">@headerStageLabel</div>
            }
        </div>
        <div class="metric-card">
            <div class="metric-label">@L("common.progress")</div>
            <div class="metric-value">@PercentLabel(progressPercent)</div>
            <div class="metric-subtle">@($"{CompletedCount(status)} / {status?.VideosTotal ?? 0}")</div>
            <div class="progress-track mt-3">
                <div class="progress-fill" style="width:@(progressPercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"></div>
            </div>
        </div>
        <div class="metric-card">
            <div class="metric-label">@L("details.current_file")</div>
            <div class="metric-value">@(string.IsNullOrWhiteSpace(status?.CurrentMedia) ? "-" : status?.CurrentMedia)</div>
            <div class="metric-subtle">@currentFileElapsed</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">@L("details.elapsed_time")</div>
            <div class="metric-value">@FormatDurationOrDash(run.ElapsedWallSec)</div>
            <div class="metric-subtle">@FormatDurationFriendly(status?.TotalDurationSec)</div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <div class="panel">
            <div class="mb-4 flex items-center justify-between gap-3">
                <div>
                    <h2 class="section-title">@L("details.generated_timeline")</h2>
                </div>
                <span class="badge-chip">@run.ArtifactItems.Count</span>
            </div>
            <div class="table-shell">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>@L("common.source")</th>
                            <th>@L("common.status")</th>
                            <th>@L("details.speakers")</th>
                            <th>@L("common.actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (run.ArtifactItems.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-8 text-center text-sm text-slate-500">@L("details.generated_timeline_empty")</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in run.ArtifactItems)
                            {
                                <tr>
                                    <td class="text-slate-700">
                                        <div class="font-medium text-slate-900">@DisplayFileName(item)</div>
                                    </td>
                                    <td class="text-slate-700">
                                        <div class="font-medium text-slate-900">@ItemStatusLabel(item.Status)</div>
                                        @if (item.IsCacheReused)
                                        {
                                            <div class="mt-1 text-xs text-slate-500">@L("details.cache_reused")</div>
                                        }
                                        @if (item.IsReferencedDuplicate && !string.IsNullOrWhiteSpace(item.ReferencedJobId))
                                        {
                                            <div class="mt-1 text-xs text-slate-500">
                                                @($"{L("details.reused_from_job")}:")
                                                <a class="text-sky-700 hover:text-sky-500" href="@JobUrls.Details(item.ReferencedJobId!)">@item.ReferencedJobId</a>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-slate-600">
                                        <div class="font-medium text-slate-900">@(item.SpeakerCount?.ToString() ?? "-")</div>
                                        @if (!string.IsNullOrWhiteSpace(item.SpeakerCountStatus))
                                        {
                                            <div class="mt-1 text-xs text-slate-500">@SpeakerStatusLabel(item.SpeakerCountStatus)</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="flex flex-wrap gap-2">
                                            @if (!string.IsNullOrWhiteSpace(item.ReadableTextPath))
                                            {
                                                <a class="btn-table" href="@ArtifactUrl(item, "readable-text")">@L("artifact.readable_text")</a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.IpaPath))
                                            {
                                                <a class="btn-table" href="@ArtifactUrl(item, "ipa")">@L("artifact.ipa")</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-6">
            @if (isActive)
            {
                <div class="panel">
                    <h2 class="section-title">@L("details.current_processing")</h2>
                    <dl class="mt-4 grid gap-4 text-sm text-slate-700">
                        <div>
                            <dt class="text-slate-500">@L("details.current_file")</dt>
                            <dd>@(string.IsNullOrWhiteSpace(status?.CurrentMedia) ? "-" : status?.CurrentMedia)</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500">@L("details.current_file_elapsed")</dt>
                            <dd>@currentFileElapsed</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500">@L("details.message")</dt>
                            <dd>@(string.IsNullOrWhiteSpace(status?.Message) ? "-" : status?.Message)</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500">@L("details.processed_duration")</dt>
                            <dd>@FormatDurationFriendly(status?.ProcessedDurationSec)</dd>
                        </div>
                        <div>
                            <dt class="text-slate-500">@L("details.total_duration")</dt>
                            <dd>@FormatDurationFriendly(status?.TotalDurationSec)</dd>
                        </div>
                    </dl>
                </div>
            }

            <div class="panel timeline-shell">
                <h2 class="section-title">@L("details.conversion_info")</h2>
                @if (string.IsNullOrWhiteSpace(run.ConversionInfoText))
                {
                    <div class="selection-empty mt-4">@L("details.conversion_info_empty")</div>
                }
                else
                {
                    <pre class="mt-4 text-sm leading-7 text-slate-100">@run.ConversionInfoText</pre>
                }
            </div>

            @if (skippedItems.Count > 0)
            {
                <div class="panel">
                    <div class="mb-4 flex items-center justify-between">
                        <h2 class="section-title">@L("details.skipped_inputs")</h2>
                        <span class="badge-chip">@skippedItems.Count</span>
                    </div>
                    <div class="table-shell">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>@L("common.source")</th>
                                    <th>@L("common.status")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in skippedItems)
                                {
                                    <tr>
                                        <td class="text-slate-700">
                                            <div class="font-medium text-slate-900">@item.FileName</div>
                                        </td>
                                        <td>@StageLabel(item.Status)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </section>
</section>

<div id="details-download-modal"
     class="modal-shell hidden"
     role="dialog"
     aria-modal="true"
     aria-labelledby="details-download-modal-title">
    <div class="modal-backdrop" data-download-close="true"></div>
    <div class="modal-card">
        <div class="space-y-3">
            <h2 class="section-title" id="details-download-modal-title">@L("jobs.list.download_title")</h2>
            <p class="page-description !mt-0" id="details-download-modal-message"></p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
            <a id="details-download-modal-readable" class="btn-primary hidden" href="#">@L("artifact.readable_text")</a>
            <a id="details-download-modal-ipa" class="btn-secondary hidden" href="#">@L("artifact.ipa")</a>
        </div>
        <div class="mt-6 flex items-center justify-end gap-3">
            <button type="button" class="btn-secondary" id="details-download-modal-close">@L("common.cancel")</button>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const container = document.getElementById("job-details");
            const downloadButton = document.getElementById("details-download-button");
            const downloadModal = document.getElementById("details-download-modal");
            const downloadModalMessage = document.getElementById("details-download-modal-message");
            const downloadModalReadable = document.getElementById("details-download-modal-readable");
            const downloadModalIpa = document.getElementById("details-download-modal-ipa");
            const downloadModalClose = document.getElementById("details-download-modal-close");
            if (!container) return;

            const isActive = container.dataset.active === "true";

            window.addEventListener("pageshow", (event) => {
                if (event.persisted) {
                    location.reload();
                }
            });

            if (isActive) {
                window.setInterval(() => location.reload(), 5000);
            }

            const downloadMessagePrefix = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L("jobs.list.download_message_prefix")));

            const closeDownloadModal = () => {
                downloadModal?.classList.add("hidden");
                if (downloadModalMessage) {
                    downloadModalMessage.textContent = "";
                }
                if (downloadModalReadable) {
                    downloadModalReadable.classList.add("hidden");
                    downloadModalReadable.removeAttribute("href");
                }
                if (downloadModalIpa) {
                    downloadModalIpa.classList.add("hidden");
                    downloadModalIpa.removeAttribute("href");
                }
            };

            downloadButton?.addEventListener("click", () => {
                const jobId = downloadButton.dataset.downloadJobId || "";
                const readableUrl = downloadButton.dataset.downloadReadable || "";
                const ipaUrl = downloadButton.dataset.downloadIpa || "";
                if (downloadModalMessage) {
                    downloadModalMessage.textContent = `${downloadMessagePrefix} ${jobId}`;
                }
                if (downloadModalReadable) {
                    if (readableUrl) {
                        downloadModalReadable.setAttribute("href", readableUrl);
                        downloadModalReadable.classList.remove("hidden");
                    } else {
                        downloadModalReadable.classList.add("hidden");
                        downloadModalReadable.removeAttribute("href");
                    }
                }
                if (downloadModalIpa) {
                    if (ipaUrl) {
                        downloadModalIpa.setAttribute("href", ipaUrl);
                        downloadModalIpa.classList.remove("hidden");
                    } else {
                        downloadModalIpa.classList.add("hidden");
                        downloadModalIpa.removeAttribute("href");
                    }
                }
                downloadModal?.classList.remove("hidden");
            });

            downloadModalClose?.addEventListener("click", closeDownloadModal);
            downloadModal?.querySelectorAll("[data-download-close='true']").forEach((element) => {
                element.addEventListener("click", closeDownloadModal);
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && downloadModal && !downloadModal.classList.contains("hidden")) {
                    closeDownloadModal();
                }
            });
        })();
    </script>
}
