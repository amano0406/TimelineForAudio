@page
@model PrivacyModel
@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    ViewData["Title"] = L("privacy.page_title");
}

<section class="work-surface space-y-3">
    <h1 class="text-3xl font-semibold text-slate-900 dark:text-slate-100">@ViewData["Title"]</h1>
    <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@L("privacy.description")</p>
</section>
