@inject TimelineForAudio.Web.Services.LanguageService LanguageService
@inject TimelineForAudio.Web.Services.JsonLocalizationService Localizer
@inject TimelineForAudio.Web.Services.AppInstanceService AppInstanceService
@using TimelineForAudio.Web.Models
@{
    var lang = LanguageService.Resolve(Context.Request);
    var currentLanguage = LanguageService.GetSupportedLanguages()
        .FirstOrDefault(item => string.Equals(item.Code, lang, StringComparison.OrdinalIgnoreCase))?.NativeName
        ?? lang;
    var setupState = Context.Items["SetupState"] as SetupState;
    var settingsReady = setupState?.IsReady ?? false;
    var hasJobs = setupState?.HasJobs ?? false;
    var appInstanceId = AppInstanceService.InstanceId;
    string L(string key) => Localizer.Get(lang, key);
    var currentPath = Context.Request.Path.Value ?? "/";

    string NavClass(string href, bool includeRuns = false)
    {
        var isJobsSection = string.Equals(href, "/jobs", StringComparison.OrdinalIgnoreCase) &&
            (string.Equals(currentPath, "/jobs", StringComparison.OrdinalIgnoreCase) ||
             (currentPath.StartsWith("/jobs/", StringComparison.OrdinalIgnoreCase) &&
              !currentPath.StartsWith("/jobs/new", StringComparison.OrdinalIgnoreCase)));

        var isActive =
            isJobsSection ||
            string.Equals(currentPath, href, StringComparison.OrdinalIgnoreCase) ||
            (!string.Equals(href, "/jobs", StringComparison.OrdinalIgnoreCase) &&
             currentPath.StartsWith($"{href}/", StringComparison.OrdinalIgnoreCase)) ||
            (includeRuns &&
             (string.Equals(currentPath, href, StringComparison.OrdinalIgnoreCase) ||
              currentPath.StartsWith("/runs", StringComparison.OrdinalIgnoreCase)));
        return isActive ? "nav-link nav-link-active" : "nav-link";
    }
}
<!DOCTYPE html>
<html lang="@lang" data-app-theme="workbench">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TimelineForAudio</title>
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.webmanifest" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="space-y-6">
                <div class="space-y-3">
                    <a href="/" class="brand-link brand-wordmark" aria-label="Timeline For Audio">
                        <span class="brand-wordmark-main">Timeline</span>
                        <span class="brand-wordmark-sub">For Audio</span>
                    </a>
                    <section class="sidebar-status-card">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="@(settingsReady ? "status-pill status-pill-ready" : "status-pill status-pill-blocked")">
                                @(settingsReady ? L("layout.ready") : L("layout.setup_required"))
                            </span>
                        </div>
                        <dl class="sidebar-status-meta">
                            <div class="sidebar-status-row">
                                <dt>@L("layout.language")</dt>
                                <dd>@currentLanguage</dd>
                            </div>
                            <div class="sidebar-status-row">
                                <dt>@L("layout.jobs")</dt>
                                <dd>@(hasJobs ? L("layout.ready") : "-")</dd>
                            </div>
                        </dl>
                    </section>
                </div>

                <nav class="space-y-2">
                    @if (settingsReady)
                    {
                        <a href="/jobs/new" class="@NavClass("/jobs/new")">@L("layout.new_job")</a>
                    }
                    @if (hasJobs)
                    {
                        <a href="/jobs" class="@NavClass("/jobs", includeRuns: true)">@L("layout.jobs")</a>
                    }
                    else if (settingsReady)
                    {
                        <span class="nav-link nav-link-disabled"
                              aria-disabled="true"
                              title="@L("jobs.list.empty")">
                            @L("layout.jobs")
                        </span>
                    }
                    <a href="@(settingsReady ? "/settings" : "/setup")"
                       class="@(settingsReady ? NavClass("/settings") : NavClass("/setup"))">@L("layout.settings")</a>
                </nav>
            </div>

        </aside>

        <div class="app-content">
            <main class="app-main">
                @RenderBody()
            </main>
        </div>
    </div>
    <div id="app-update-banner"
         class="fixed bottom-4 right-4 hidden rounded-xl border border-slate-200 bg-slate-950 px-4 py-3 text-sm font-medium text-white shadow-2xl">
        @L("layout.update_detected")
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (() => {
            const currentInstanceId = "@appInstanceId";
            const pollIntervalMs = 10000;
            const banner = document.getElementById("app-update-banner");

            let pendingReload = false;
            let checking = false;

            window.timelineForAudioSetBusy = (value) => {
                window.__timelineForAudioBusy = Boolean(value);
                if (!window.__timelineForAudioBusy && pendingReload) {
                    location.reload();
                }
            };

            const triggerReload = () => {
                pendingReload = true;
                banner?.classList.remove("hidden");
                if (!window.__timelineForAudioBusy) {
                    location.reload();
                }
            };

            const checkVersion = async () => {
                if (checking) {
                    return;
                }

                checking = true;
                try {
                    const response = await fetch("/api/app/version", {
                        method: "GET",
                        cache: "no-store",
                        headers: {
                            "Accept": "application/json"
                        }
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (payload?.instanceId && payload.instanceId !== currentInstanceId) {
                        triggerReload();
                    }
                } catch {
                } finally {
                    checking = false;
                }
            };

            setInterval(checkVersion, pollIntervalMs);
            document.addEventListener("visibilitychange", () => {
                if (!document.hidden) {
                    checkVersion();
                }
            });
            window.addEventListener("focus", checkVersion);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
