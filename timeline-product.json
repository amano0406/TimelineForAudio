{
  "schemaVersion": 1,
  "productId": "audio",
  "displayName": "TimelineForAudio",
  "productKind": "media-audio",
  "description": "Converts local audio files into speaker and acoustic-unit timeline items.",
  "commands": {
    "start": {
      "type": "powershell",
      "path": "start.ps1"
    },
    "stop": {
      "type": "powershell",
      "path": "stop.ps1"
    },
    "cli": {
      "type": "powershell",
      "path": "cli.ps1"
    }
  },
  "settings": {
    "file": "settings.json",
    "exampleFile": "settings.example.json",
    "supportsBasicDefaults": true,
    "supportsProductOverrides": true
  },
  "capabilities": {
    "fileList": true,
    "itemList": true,
    "itemRefresh": true,
    "itemDownload": true,
    "itemRemove": true,
    "modelList": true,
    "verbalization": true
  },
  "data": {
    "sourcePathsFromSettings": [
      "inputRoots[]"
    ],
    "generatedPathsFromSettings": [
      "outputRoot"
    ],
    "deleteSourceData": false
  },
  "uninstall": {
    "deleteAppDirectory": true,
    "backupSettingsByDefault": true,
    "deleteGeneratedDataOptional": true,
    "deleteGeneratedDataByDefault": false,
    "deleteSourceData": false
  },
  "runtime": {
    "usesDocker": true,
    "dockerManagedByTimeline": false
  }
}
