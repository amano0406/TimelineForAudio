{
  "schemaVersion": 1,
  "productId": "audio",
  "displayName": "TimelineForAudio",
  "productKind": "media-audio",
  "description": "Converts local audio files into speaker-separated transcript timeline items.",
  "commands": {
    "start": {
      "type": "powershell",
      "path": "start.ps1"
    },
    "stop": {
      "type": "powershell",
      "path": "stop.ps1"
    }
  },
  "api": {
    "enabled": true,
    "connectionMode": "api",
    "healthPath": "/health",
    "defaultHost": "localhost",
    "defaultPort": 19100,
    "defaultBaseUrl": "http://localhost:19100"
  },
  "settings": {
    "file": "settings.json",
    "exampleFile": "settings.example.json",
    "supportsBasicDefaults": true,
    "supportsProductOverrides": true,
    "supportsRuntimeApi": true,
    "supportsInstanceName": true
  },
  "capabilities": {
    "fileList": true,
    "itemList": true,
    "itemRefresh": true,
    "itemDownload": true,
    "itemRemove": true,
    "modelList": true,
    "verbalization": true
  },
  "data": {
    "sourcePathsFromSettings": [
      "inputRoots[]"
    ],
    "generatedPathsFromSettings": [
      "outputRoot"
    ],
    "deleteSourceData": false
  },
  "uninstall": {
    "deleteAppDirectory": true,
    "backupSettingsByDefault": true,
    "deleteGeneratedDataOptional": true,
    "deleteGeneratedDataByDefault": false,
    "deleteSourceData": false
  },
  "runtime": {
    "usesDocker": true,
    "dockerManagedByTimeline": false,
    "hostApi": true,
    "healthApi": true
  }
}
